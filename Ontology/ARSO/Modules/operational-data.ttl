@prefix arso: <https://w3id.org/2025/arso#> .
@prefix aas:  <https://admin-shell.io/aas/3/1/> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .


#### STILL UNDER DEVELOPMENT - This is currently a placeholder for the concept of "Operational Data".

#################################################################
# SMT STRUCTURE OVERVIEW
#################################################################
# OperationalData (Submodel)
#   ├─ Datapoint [Property, 1..*]
#   │    ├─ valueType constrained to xs:decimal
#   │    └─ semanticId required
#   └─ DatapointGroup [SMC, 0..*]
#        └─ contains only Datapoint children

#################################################################
# ONTOLOGY METADATA
#################################################################

<https://w3id.org/2025/arso/modules/operational-data>
  rdf:type owl:Ontology ;
  owl:imports <https://admin-shell.io/aas/3/1/> ;
  rdfs:comment """ARSO module: Operational Data (Custom).""" .


#################################################################
# SUBMODEL TYPE
#################################################################

arso:OperationalDataSubmodel rdf:type owl:Class ;
  rdfs:subClassOf aas:Submodel ;
  rdfs:label "Operational Data Submodel" ;
  rdfs:comment "Custom — Runtime variable bindings." .


#################################################################
# ELEMENT TYPES
#################################################################

arso:Datapoint rdf:type owl:Class ;
  rdfs:subClassOf aas:Property ;
  rdfs:comment "A domain-specific measurement or value, represented as an AAS Property." .

arso:DatapointGroup rdf:type owl:Class ;
  rdfs:subClassOf aas:SubmodelElementCollection ;
  rdfs:comment "A structured group of Datapoints." .


#################################################################
# ELEMENT CONSTRAINTS
#################################################################

# Datapoint must use decimal values
arso:Datapoint rdfs:subClassOf [
  rdf:type owl:Restriction ;
  owl:onProperty <https://admin-shell.io/aas/3/1/Property/valueType> ;
  owl:hasValue <https://admin-shell.io/aas/3/1/DataTypeDefXsd/Decimal> ] .

# Datapoint must have exactly one value
arso:Datapoint rdfs:subClassOf [
  rdf:type owl:Restriction ;
  owl:onProperty <https://admin-shell.io/aas/3/1/Property/value> ;
  owl:cardinality "1"^^xsd:nonNegativeInteger ] .

# Datapoint must have a semanticId
arso:Datapoint rdfs:subClassOf [
  rdf:type owl:Restriction ;
  owl:onProperty <https://admin-shell.io/aas/3/1/HasSemantics/semanticId> ;
  owl:minCardinality "1"^^xsd:nonNegativeInteger ] .

# DatapointGroup may only contain Datapoints
arso:DatapointGroup rdfs:subClassOf [
  rdf:type owl:Restriction ;
  owl:onProperty <https://admin-shell.io/aas/3/1/SubmodelElementCollection/value> ;
  owl:allValuesFrom arso:Datapoint ] .


#################################################################
# CONTAINMENT CONSTRAINTS
#################################################################

arso:OperationalDataSubmodel rdfs:subClassOf [
  rdf:type owl:Restriction ;
  owl:onProperty <https://admin-shell.io/aas/3/1/Submodel/submodelElements> ;
  owl:someValuesFrom arso:Datapoint ] .
