        owl:ObjectProperty ;
    rdfs:range <https://w3id.org/2025/apso#BillOfProcessSubmodel> ;
    rdfs:subPropertyOf <https://w3id.org/2025/apso#hasSubmodel> .

<https://admin-shell.io/aas/3/1/QualifierKind> a owl:Class ;
    rdfs:label "Qualifier Kind"^^xsd:string ;
    rdfs:comment "Enumeration for kinds of qualifiers."@en ;
    owl:oneOf ( <https://admin-shell.io/aas/3/1/QualifierKind/ConceptQualifier> <https://admin-shell.io/aas/3/1/QualifierKind/TemplateQualifier> <https://admin-shell.io/aas/3/1/QualifierKind/ValueQualifier> ) .

<https://admin-shell.io/aas/3/1/SubmodelElementList/value> a owl:ObjectProperty ;
    rdfs:label "has value"^^xsd:string ;
    rdfs:comment "Submodel element contained in the list."@en ;
    rdfs:domain <https://admin-shell.io/aas/3/1/SubmodelElementList> ;
    rdfs:range <https://admin-shell.io/aas/3/1/SubmodelElement> .

<https://admin-shell.io/aas/3/1/> a owl:Ontology ;
    rdfs:comment "This ontology represents the data model for the Asset Administration Shell according to the specification version V3.1."@en ;
    rdfs:isDefinedBy <https://admin-shell.io/aas/3/1/> ;
    owl:versionInfo "V3.1" .

<https://admin-shell.io/aas/3/1/AssetKind> a owl:Class ;
    rdfs:label "Asset Kind"^^xsd:string ;
    rdfs:comment "Enumeration for denoting whether an asset is a type asset or an instance asset."@en ;
    owl:oneOf ( <https://admin-shell.io/aas/3/1/AssetKind/Instance> <https://admin-shell.io/aas/3/1/AssetKind/NotApplicable> <https://admin-shell.io/aas/3/1/AssetKind/Role> <https://admin-shell.io/aas/3/1/AssetKind/Type> ) .

<https://admin-shell.io/aas/3/1/RelationshipElement/first> a owl:ObjectProperty ;
    rdfs:label "has first"^^xsd:string ;
    rdfs:comment "Reference to the first element in the relationship taking the role of the subject."@en ;
    rdfs:domain <https://admin-shell.io/aas/3/1/RelationshipElement> ;
    rdfs:range <https://admin-shell.io/aas/3/1/Reference> .

<https://admin-shell.io/aas/3/1/RelationshipElement/second> a owl:ObjectProperty ;
    rdfs:label "has second"^^xsd:string ;
    rdfs:comment "Reference to the second element in the relationship taking the role of the object."@en ;
    rdfs:domain <https://admin-shell.io/aas/3/1/RelationshipElement> ;
    rdfs:range <https://admin-shell.io/aas/3/1/Reference> .

<https://w3id.org/2025/apso#hasSubmodel> a owl:ObjectProperty ;
    rdfs:comment "Direct link from AAS to a submodel instance, bypassing AAS Reference indirection." ;
    rdfs:domain <https://admin-shell.io/aas/3/1/AssetAdministrationShell> ;
    rdfs:range <https://admin-shell.io/aas/3/1/Submodel> .

<https://admin-shell.io/aas/3/1/AnnotatedRelationshipElement/annotations> a owl:ObjectProperty ;
    rdfs:label "has annotations"^^xsd:string ;
    rdfs:comment "A data element that represents an annotation that holds for the relationship between the two elements"@en ;
    rdfs:domain <https://admin-shell.io/aas/3/1/AnnotatedRelationshipElement> ;
    rdfs:range <https://admin-shell.io/aas/3/1/DataElement> .

<https://admin-shell.io/aas/3/1/DataElement> a owl:Class ;
    rdfs:label "Data Element"^^xsd:string ;
    rdfs:comment "A data element is a submodel element that is not further composed out of other submodel elements."@en ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/SubmodelElement> .

<https://admin-shell.io/aas/3/1/AasSubmodelElements> a owl:Class ;
    rdfs:label "AAS Submodel Elements"^^xsd:string ;
    rdfs:comment "Enumeration of all possible elements of a 'SubmodelElementList'."@en ;
    owl:oneOf ( <https://admin-shell.io/aas/3/1/AasSubmodelElements/AnnotatedRelationshipElement> <https://admin-shell.io/aas/3/1/AasSubmodelElements/BasicEventElement> <https://admin-shell.io/aas/3/1/AasSubmodelElements/Blob> <https://admin-shell.io/aas/3/1/AasSubmodelElements/Capability> <https://admin-shell.io/aas/3/1/AasSubmodelElements/DataElement> <https://admin-shell.io/aas/3/1/AasSubmodelElements/Entity> <https://admin-shell.io/aas/3/1/AasSubmodelElements/EventElement> <https://admin-shell.io/aas/3/1/AasSubmodelElements/File> <https://admin-shell.io/aas/3/1/AasSubmodelElements/MultiLanguageProperty> <https://admin-shell.io/aas/3/1/AasSubmodelElements/Operation> <https://admin-shell.io/aas/3/1/AasSubmodelElements/Property> <https://admin-shell.io/aas/3/1/AasSubmodelElements/Range> <https://admin-shell.io/aas/3/1/AasSubmodelElements/ReferenceElement> <https://admin-shell.io/aas/3/1/AasSubmodelElements/RelationshipElement> <https://admin-shell.io/aas/3/1/AasSubmodelElements/SubmodelElement> <https://admin-shell.io/aas/3/1/AasSubmodelElements/SubmodelElementCollection> <https://admin-shell.io/aas/3/1/AasSubmodelElements/SubmodelElementList> ) .

<https://admin-shell.io/aas/3/1/DataTypeIec61360> a owl:Class ;
    rdfs:label "Data Type IEC 61360"^^xsd:string ;
    owl:oneOf ( <https://admin-shell.io/aas/3/1/DataTypeIec61360/Blob> <https://admin-shell.io/aas/3/1/DataTypeIec61360/Boolean> <https://admin-shell.io/aas/3/1/DataTypeIec61360/Date> <https://admin-shell.io/aas/3/1/DataTypeIec61360/File> <https://admin-shell.io/aas/3/1/DataTypeIec61360/Html> <https://admin-shell.io/aas/3/1/DataTypeIec61360/IntegerCount> <https://admin-shell.io/aas/3/1/DataTypeIec61360/IntegerCurrency> <https://admin-shell.io/aas/3/1/DataTypeIec61360/IntegerMeasure> <https://admin-shell.io/aas/3/1/DataTypeIec61360/Irdi> <https://admin-shell.io/aas/3/1/DataTypeIec61360/Iri> <https://admin-shell.io/aas/3/1/DataTypeIec61360/Rational> <https://admin-shell.io/aas/3/1/DataTypeIec61360/RationalMeasure> <https://admin-shell.io/aas/3/1/DataTypeIec61360/RealCount> <https://admin-shell.io/aas/3/1/DataTypeIec61360/RealCurrency> <https://admin-shell.io/aas/3/1/DataTypeIec61360/RealMeasure> <https://admin-shell.io/aas/3/1/DataTypeIec61360/String> <https://admin-shell.io/aas/3/1/DataTypeIec61360/StringTranslatable> <https://admin-shell.io/aas/3/1/DataTypeIec61360/Time> <https://admin-shell.io/aas/3/1/DataTypeIec61360/Timestamp> ) .

<https://admin-shell.io/aas/3/1/KeyTypes> a owl:Class ;
    rdfs:label "Key Types"^^xsd:string ;
    rdfs:comment "Enumeration of different key value types within a key."@en ;
    owl:oneOf ( <https://admin-shell.io/aas/3/1/KeyTypes/AnnotatedRelationshipElement> <https://admin-shell.io/aas/3/1/KeyTypes/AssetAdministrationShell> <https://admin-shell.io/aas/3/1/KeyTypes/BasicEventElement> <https://admin-shell.io/aas/3/1/KeyTypes/Blob> <https://admin-shell.io/aas/3/1/KeyTypes/Capability> <https://admin-shell.io/aas/3/1/KeyTypes/ConceptDescription> <https://admin-shell.io/aas/3/1/KeyTypes/DataElement> <https://admin-shell.io/aas/3/1/KeyTypes/Entity> <https://admin-shell.io/aas/3/1/KeyTypes/EventElement> <https://admin-shell.io/aas/3/1/KeyTypes/File> <https://admin-shell.io/aas/3/1/KeyTypes/FragmentReference> <https://admin-shell.io/aas/3/1/KeyTypes/GlobalReference> <https://admin-shell.io/aas/3/1/KeyTypes/Identifiable> <https://admin-shell.io/aas/3/1/KeyTypes/MultiLanguageProperty> <https://admin-shell.io/aas/3/1/KeyTypes/Operation> <https://admin-shell.io/aas/3/1/KeyTypes/Property> <https://admin-shell.io/aas/3/1/KeyTypes/Range> <https://admin-shell.io/aas/3/1/KeyTypes/Referable> <https://admin-shell.io/aas/3/1/KeyTypes/ReferenceElement> <https://admin-shell.io/aas/3/1/KeyTypes/RelationshipElement> <https://admin-shell.io/aas/3/1/KeyTypes/Submodel> <https://admin-shell.io/aas/3/1/KeyTypes/SubmodelElement> <https://admin-shell.io/aas/3/1/KeyTypes/SubmodelElementCollection> <https://admin-shell.io/aas/3/1/KeyTypes/SubmodelElementList> ) .

<https://admin-shell.io/aas/3/1/Submodel/submodelElements> a owl:ObjectProperty ;
    rdfs:label "has submodel elements"^^xsd:string ;
    rdfs:comment "A submodel consists of zero or more submodel elements."@en ;
    rdfs:domain <https://admin-shell.io/aas/3/1/Submodel> ;
    rdfs:range <https://admin-shell.io/aas/3/1/SubmodelElement> .

<https://admin-shell.io/aas/3/1/SubmodelElement> a owl:Class ;
    rdfs:label "Submodel Element"^^xsd:string ;
    rdfs:comment "A submodel element is an element suitable for the description and differentiation of assets."@en ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/HasDataSpecification>,
        <https://admin-shell.io/aas/3/1/HasSemantics>,
        <https://admin-shell.io/aas/3/1/Qualifiable>,
        <https://admin-shell.io/aas/3/1/Referable> .

<https://admin-shell.io/aas/3/1/DataTypeDefXsd> a owl:Class ;
