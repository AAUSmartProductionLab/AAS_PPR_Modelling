<https://admin-shell.io/aas/3/1/AbstractLangString> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:label "Abstract Lang String"^^xsd:string ;
    rdfs:comment "Strings with language tags"@en ;
    sh:property <https://admin-shell.io/aas/3/1/AbstractLangString-https___admin-shell.io_aas_3_1_AbstractLangString_language>,
        <https://admin-shell.io/aas/3/1/AbstractLangString-https___admin-shell.io_aas_3_1_AbstractLangString_text> .

<https://admin-shell.io/aas/3/1/AdministrativeInformation> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:label "Administrative Information"^^xsd:string ;
    rdfs:comment "Administrative meta-information for an element like version information."@en ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/HasDataSpecification> ;
    sh:property <https://admin-shell.io/aas/3/1/AdministrativeInformation-https___admin-shell.io_aas_3_1_AdministrativeInformation_creator>,
        <https://admin-shell.io/aas/3/1/AdministrativeInformation-https___admin-shell.io_aas_3_1_AdministrativeInformation_revision>,
        <https://admin-shell.io/aas/3/1/AdministrativeInformation-https___admin-shell.io_aas_3_1_AdministrativeInformation_templateId>,
        <https://admin-shell.io/aas/3/1/AdministrativeInformation-https___admin-shell.io_aas_3_1_AdministrativeInformation_version> .

<https://admin-shell.io/aas/3/1/AnnotatedRelationshipElement> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:label "Annotated Relationship Element"^^xsd:string ;
    rdfs:comment "An annotated relationship element is a relationship element that can be annotated with additional data elements."@en ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/RelationshipElement> ;
    sh:property <https://admin-shell.io/aas/3/1/AnnotatedRelationshipElement-https___admin-shell.io_aas_3_1_AnnotatedRelationshipElement_annotations> .

<https://admin-shell.io/aas/3/1/AssetAdministrationShell> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:label "Asset Administration Shell"^^xsd:string ;
    rdfs:comment "An asset administration shell."@en ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/HasDataSpecification>,
        <https://admin-shell.io/aas/3/1/Identifiable> ;
    sh:property <https://admin-shell.io/aas/3/1/AssetAdministrationShell-hasSubmodel>,
        <https://admin-shell.io/aas/3/1/AssetAdministrationShell-https___admin-shell.io_aas_3_1_AssetAdministrationShell_assetInformation>,
        <https://admin-shell.io/aas/3/1/AssetAdministrationShell-https___admin-shell.io_aas_3_1_AssetAdministrationShell_derivedFrom>,
        <https://admin-shell.io/aas/3/1/AssetAdministrationShell-https___admin-shell.io_aas_3_1_AssetAdministrationShell_submodels> .

<https://admin-shell.io/aas/3/1/AssetInformation> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:label "Asset Information"^^xsd:string ;
    rdfs:comment "In 'AssetInformation' identifying meta data of the asset that is represented by an AAS is defined."@en ;
    sh:property <https://admin-shell.io/aas/3/1/AssetInformation-https___admin-shell.io_aas_3_1_AssetInformation_assetKind>,
        <https://admin-shell.io/aas/3/1/AssetInformation-https___admin-shell.io_aas_3_1_AssetInformation_assetType>,
        <https://admin-shell.io/aas/3/1/AssetInformation-https___admin-shell.io_aas_3_1_AssetInformation_defaultThumbnail>,
        <https://admin-shell.io/aas/3/1/AssetInformation-https___admin-shell.io_aas_3_1_AssetInformation_globalAssetId>,
        <https://admin-shell.io/aas/3/1/AssetInformation-https___admin-shell.io_aas_3_1_AssetInformation_specificAssetIds> .

<https://admin-shell.io/aas/3/1/BasicEventElement> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:label "Basic Event Element"^^xsd:string ;
    rdfs:comment "A basic event element."@en ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/EventElement> ;
    sh:property <https://admin-shell.io/aas/3/1/BasicEventElement-https___admin-shell.io_aas_3_1_BasicEventElement_direction>,
        <https://admin-shell.io/aas/3/1/BasicEventElement-https___admin-shell.io_aas_3_1_BasicEventElement_lastUpdate>,
        <https://admin-shell.io/aas/3/1/BasicEventElement-https___admin-shell.io_aas_3_1_BasicEventElement_maxInterval>,
        <https://admin-shell.io/aas/3/1/BasicEventElement-https___admin-shell.io_aas_3_1_BasicEventElement_messageBroker>,
        <https://admin-shell.io/aas/3/1/BasicEventElement-https___admin-shell.io_aas_3_1_BasicEventElement_messageTopic>,
        <https://admin-shell.io/aas/3/1/BasicEventElement-https___admin-shell.io_aas_3_1_BasicEventElement_minInterval>,
        <https://admin-shell.io/aas/3/1/BasicEventElement-https___admin-shell.io_aas_3_1_BasicEventElement_observed>,
        <https://admin-shell.io/aas/3/1/BasicEventElement-https___admin-shell.io_aas_3_1_BasicEventElement_state> .

<https://admin-shell.io/aas/3/1/Blob> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:label "Blob"^^xsd:string ;
    rdfs:comment "A 'Blob' is a data element that represents a file that is contained with its source code in the value attribute."@en ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/DataElement> ;
    sh:property <https://admin-shell.io/aas/3/1/Blob-https___admin-shell.io_aas_3_1_Blob_contentType>,
        <https://admin-shell.io/aas/3/1/Blob-https___admin-shell.io_aas_3_1_Blob_value> .

<https://admin-shell.io/aas/3/1/ConceptDescription> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:label "Concept Description"^^xsd:string ;
    rdfs:comment "The semantics of a property or other elements that may have a semantic description is defined by a concept description."@en ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/HasDataSpecification>,
        <https://admin-shell.io/aas/3/1/Identifiable> ;
    sh:property <https://admin-shell.io/aas/3/1/ConceptDescription-https___admin-shell.io_aas_3_1_ConceptDescription_isCaseOf> .

<https://admin-shell.io/aas/3/1/DataSpecificationIec61360> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:label "Data Specification IEC 61360"^^xsd:string ;
    rdfs:comment "Content of data specification template for concept descriptions for properties, values and value lists conformant to IEC 61360."@en ;
