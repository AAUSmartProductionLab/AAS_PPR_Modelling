        <https://admin-shell.io/aas/3/1/Entity-https___admin-shell.io_aas_3_1_Entity_statements> .

<https://admin-shell.io/aas/3/1/Environment> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:label "Environment"^^xsd:string ;
    rdfs:comment "Container for the sets of different identifiables."@en ;
    sh:property <https://admin-shell.io/aas/3/1/Environment-https___admin-shell.io_aas_3_1_Environment_assetAdministrationShells>,
        <https://admin-shell.io/aas/3/1/Environment-https___admin-shell.io_aas_3_1_Environment_conceptDescriptions>,
        <https://admin-shell.io/aas/3/1/Environment-https___admin-shell.io_aas_3_1_Environment_submodels> .

<https://admin-shell.io/aas/3/1/EventPayload> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:label "Event Payload"^^xsd:string ;
    rdfs:comment "Defines the necessary information of an event instance sent out or received."@en ;
    sh:property <https://admin-shell.io/aas/3/1/EventPayload-https___admin-shell.io_aas_3_1_EventPayload_observableReference>,
        <https://admin-shell.io/aas/3/1/EventPayload-https___admin-shell.io_aas_3_1_EventPayload_observableSemanticId>,
        <https://admin-shell.io/aas/3/1/EventPayload-https___admin-shell.io_aas_3_1_EventPayload_payload>,
        <https://admin-shell.io/aas/3/1/EventPayload-https___admin-shell.io_aas_3_1_EventPayload_source>,
        <https://admin-shell.io/aas/3/1/EventPayload-https___admin-shell.io_aas_3_1_EventPayload_sourceSemanticId>,
        <https://admin-shell.io/aas/3/1/EventPayload-https___admin-shell.io_aas_3_1_EventPayload_subjectId>,
        <https://admin-shell.io/aas/3/1/EventPayload-https___admin-shell.io_aas_3_1_EventPayload_timeStamp>,
        <https://admin-shell.io/aas/3/1/EventPayload-https___admin-shell.io_aas_3_1_EventPayload_topic> .

<https://admin-shell.io/aas/3/1/Extension> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:label "Extension"^^xsd:string ;
    rdfs:comment "Single extension of an element."@en ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/HasSemantics> ;
    sh:property <https://admin-shell.io/aas/3/1/Extension-https___admin-shell.io_aas_3_1_Extension_name>,
        <https://admin-shell.io/aas/3/1/Extension-https___admin-shell.io_aas_3_1_Extension_refersTo>,
        <https://admin-shell.io/aas/3/1/Extension-https___admin-shell.io_aas_3_1_Extension_value>,
        <https://admin-shell.io/aas/3/1/Extension-https___admin-shell.io_aas_3_1_Extension_valueType> .

<https://admin-shell.io/aas/3/1/File> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:label "File"^^xsd:string ;
    rdfs:comment "A File is a data element that represents an address to a file (a locator)."@en ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/DataElement> ;
    sh:property <https://admin-shell.io/aas/3/1/File-https___admin-shell.io_aas_3_1_File_contentType>,
        <https://admin-shell.io/aas/3/1/File-https___admin-shell.io_aas_3_1_File_value> .

<https://admin-shell.io/aas/3/1/HasDataSpecification> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:label "Has Data Specification"^^xsd:string ;
    rdfs:comment "Element that can be extended by using data specification templates."@en ;
    sh:property <https://admin-shell.io/aas/3/1/HasDataSpecification-https___admin-shell.io_aas_3_1_HasDataSpecification_embeddedDataSpecifications> .

<https://admin-shell.io/aas/3/1/HasExtensions> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:label "Has Extensions"^^xsd:string ;
    rdfs:comment "Element that can be extended by proprietary extensions."@en ;
    sh:property <https://admin-shell.io/aas/3/1/HasExtensions-https___admin-shell.io_aas_3_1_HasExtensions_extensions> .

<https://admin-shell.io/aas/3/1/HasKind> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:label "Has Kind"^^xsd:string ;
    rdfs:comment "An element with a kind is an element that can either represent a template or an instance."@en ;
    sh:property <https://admin-shell.io/aas/3/1/HasKind-https___admin-shell.io_aas_3_1_HasKind_kind> .

<https://admin-shell.io/aas/3/1/HasSemantics> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:label "Has Semantics"^^xsd:string ;
    rdfs:comment "Element that can have a semantic definition plus some supplemental semantic definitions."@en ;
    sh:property <https://admin-shell.io/aas/3/1/HasSemantics-https___admin-shell.io_aas_3_1_HasSemantics_semanticId>,
        <https://admin-shell.io/aas/3/1/HasSemantics-https___admin-shell.io_aas_3_1_HasSemantics_supplementalSemanticIds> .

<https://admin-shell.io/aas/3/1/Identifiable> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:label "Identifiable"^^xsd:string ;
    rdfs:comment "An element that has a globally unique identifier."@en ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/Referable> ;
    sh:property <https://admin-shell.io/aas/3/1/Identifiable-https___admin-shell.io_aas_3_1_Identifiable_administration>,
        <https://admin-shell.io/aas/3/1/Identifiable-https___admin-shell.io_aas_3_1_Identifiable_id> .

<https://admin-shell.io/aas/3/1/Key> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:label "Key"^^xsd:string ;
    rdfs:comment "A key is a reference to an element by its ID."@en ;
    sh:property <https://admin-shell.io/aas/3/1/Key-https___admin-shell.io_aas_3_1_Key_type>,
        <https://admin-shell.io/aas/3/1/Key-https___admin-shell.io_aas_3_1_Key_value> .

<https://admin-shell.io/aas/3/1/LevelType> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:label "Level Type"^^xsd:string ;
    rdfs:comment "Value represented by up to four variants of a numeric value in a specific role: MIN, NOM, TYP and MAX. True means that the value is available, false means the value is not available."@en ;
    sh:property <https://admin-shell.io/aas/3/1/LevelType-https___admin-shell.io_aas_3_1_LevelType_max>,
        <https://admin-shell.io/aas/3/1/LevelType-https___admin-shell.io_aas_3_1_LevelType_min>,
        <https://admin-shell.io/aas/3/1/LevelType-https___admin-shell.io_aas_3_1_LevelType_nom>,
        <https://admin-shell.io/aas/3/1/LevelType-https___admin-shell.io_aas_3_1_LevelType_typ> .

<https://admin-shell.io/aas/3/1/MultiLanguageProperty> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:label "Multi Language Property"^^xsd:string ;
    rdfs:comment "A property is a data element that has a multi-language value."@en ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/DataElement> ;
    sh:property <https://admin-shell.io/aas/3/1/MultiLanguageProperty-https___admin-shell.io_aas_3_1_MultiLanguageProperty_value>,
        <https://admin-shell.io/aas/3/1/MultiLanguageProperty-https___admin-shell.io_aas_3_1_MultiLanguageProperty_valueId> .

<https://admin-shell.io/aas/3/1/Operation> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:label "Operation"^^xsd:string ;
    rdfs:comment "An operation is a submodel element with input and output variables."@en ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/SubmodelElement> ;
    sh:property <https://admin-shell.io/aas/3/1/Operation-https___admin-shell.io_aas_3_1_Operation_inoutputVariables>,
        <https://admin-shell.io/aas/3/1/Operation-https___admin-shell.io_aas_3_1_Operation_inputVariables>,
        <https://admin-shell.io/aas/3/1/Operation-https___admin-shell.io_aas_3_1_Operation_outputVariables> .

<https://admin-shell.io/aas/3/1/OperationVariable> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:label "Operation Variable"^^xsd:string ;
    rdfs:comment "The value of an operation variable is a submodel element that is used as input and/or output variable of an operation."@en ;
    sh:property <https://admin-shell.io/aas/3/1/OperationVariable-https___admin-shell.io_aas_3_1_OperationVariable_value> .

<https://admin-shell.io/aas/3/1/Property> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:label "Property"^^xsd:string ;
    rdfs:comment "A property is a data element that has a single value."@en ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/DataElement> ;
    sh:property <https://admin-shell.io/aas/3/1/Property-https___admin-shell.io_aas_3_1_Property_value>,
        <https://admin-shell.io/aas/3/1/Property-https___admin-shell.io_aas_3_1_Property_valueId>,
        <https://admin-shell.io/aas/3/1/Property-https___admin-shell.io_aas_3_1_Property_valueType> .

<https://admin-shell.io/aas/3/1/Qualifiable> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:label "Qualifiable"^^xsd:string ;
    rdfs:comment "The value of a qualifiable element may be further qualified by one or more qualifiers."@en ;
    sh:property <https://admin-shell.io/aas/3/1/Qualifiable-https___admin-shell.io_aas_3_1_Qualifiable_qualifiers> .

<https://admin-shell.io/aas/3/1/Qualifier> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:label "Qualifier"^^xsd:string ;
    rdfs:comment "A qualifier is a type-value-pair that makes additional statements w.r.t. the value of the element."@en ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/HasSemantics> ;
    sh:property <https://admin-shell.io/aas/3/1/Qualifier-https___admin-shell.io_aas_3_1_Qualifier_kind>,
        <https://admin-shell.io/aas/3/1/Qualifier-https___admin-shell.io_aas_3_1_Qualifier_type>,
        <https://admin-shell.io/aas/3/1/Qualifier-https___admin-shell.io_aas_3_1_Qualifier_value>,
        <https://admin-shell.io/aas/3/1/Qualifier-https___admin-shell.io_aas_3_1_Qualifier_valueId>,
        <https://admin-shell.io/aas/3/1/Qualifier-https___admin-shell.io_aas_3_1_Qualifier_valueType> .

<https://admin-shell.io/aas/3/1/Range> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:label "Range"^^xsd:string ;
    rdfs:comment "A range data element is a data element that defines a range with min and max."@en ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/DataElement> ;
    sh:property <https://admin-shell.io/aas/3/1/Range-https___admin-shell.io_aas_3_1_Range_max>,
        <https://admin-shell.io/aas/3/1/Range-https___admin-shell.io_aas_3_1_Range_min>,
        <https://admin-shell.io/aas/3/1/Range-https___admin-shell.io_aas_3_1_Range_valueType> .

<https://admin-shell.io/aas/3/1/Referable> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:label "Referable"^^xsd:string ;
    rdfs:comment "An element that is referable by its 'idShort'."@en ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/HasExtensions> ;
    sh:property <https://admin-shell.io/aas/3/1/Referable-https___admin-shell.io_aas_3_1_Referable_category>,
        <https://admin-shell.io/aas/3/1/Referable-https___admin-shell.io_aas_3_1_Referable_description>,
        <https://admin-shell.io/aas/3/1/Referable-https___admin-shell.io_aas_3_1_Referable_displayName>,
        <https://admin-shell.io/aas/3/1/Referable-https___admin-shell.io_aas_3_1_Referable_idShort> .

<https://admin-shell.io/aas/3/1/Reference> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:label "Reference"^^xsd:string ;
    rdfs:comment "Reference to either a model element of the same or another AAS or to an external entity."@en ;
    sh:property <https://admin-shell.io/aas/3/1/Reference-https___admin-shell.io_aas_3_1_Reference_keys>,
        <https://admin-shell.io/aas/3/1/Reference-https___admin-shell.io_aas_3_1_Reference_referredSemanticId>,
        <https://admin-shell.io/aas/3/1/Reference-https___admin-shell.io_aas_3_1_Reference_type> .

<https://admin-shell.io/aas/3/1/ReferenceElement> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:label "Reference Element"^^xsd:string ;
    rdfs:comment "A reference element is a data element that defines a logical reference to another element within the same or another AAS or a reference to an external object or entity."@en ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/DataElement> ;
    sh:property <https://admin-shell.io/aas/3/1/ReferenceElement-https___admin-shell.io_aas_3_1_ReferenceElement_value> .

<https://admin-shell.io/aas/3/1/RelationshipElement> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
