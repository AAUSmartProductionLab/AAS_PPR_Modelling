    rdfs:subClassOf <https://admin-shell.io/aas/3/1/MultiLanguageProperty> .

<https://w3id.org/2025/arso#AddressZipcodeMLP> a owl:Class ;
    rdfs:comment "MLP Zipcode within AddressInformation — mandatory per section 3.2. semanticId: 0173-1#02-AAO129#002." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/MultiLanguageProperty> .

<https://w3id.org/2025/arso#BulkCountProperty> a owl:Class ;
    rdfs:comment "Property BulkCount (xs:unsignedLong) — count of identical bulk items represented by this node. Only valid on NodeEntity; presence implies the node represents a type-level asset, not a specific instance." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/Property> .

<https://w3id.org/2025/arso#CCErrorsSMC> a owl:Class ;
    rdfs:comment "SMC Errors — mandatory top-level container for global CC error entries. Always present, may be empty." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/SubmodelElementCollection> .

<https://w3id.org/2025/arso#CCInterfaceProfileMLP> a owl:Class ;
    rdfs:comment "MLP InterfaceProfile — human-readable description of the CC interface profile." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/MultiLanguageProperty> .

<https://w3id.org/2025/arso#CCInterfaceReferenceRef> a owl:Class ;
    rdfs:comment "ReferenceElement InterfaceReference — points to an arso:InterfaceSMC within the AIDSubmodel of the same AAS. Cross-SM enforcement via SPARQL SHACL." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/ReferenceElement> .

<https://w3id.org/2025/arso#CCInterfacesSMC> a owl:Class ;
    rdfs:comment "SMC Interfaces — mandatory top-level container for all CC interface entries. Always present, may be empty." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/SubmodelElementCollection> .

<https://w3id.org/2025/arso#CCSkillsSMC> a owl:Class ;
    rdfs:comment "SMC Skills — mandatory top-level container for all Skill entries. Always present, may be empty." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/SubmodelElementCollection> .

<https://w3id.org/2025/arso#CapabilityElement> a owl:Class ;
    rdfs:comment "Capability element — implementation-independent specification of a function in industrial production. semanticId: https://admin-shell.io/idta/CapabilityDescription/Capability/1/0. Qualified by CapabilityRoleQualifier (Required|Offered|NotAssigned)." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/Capability> .

<https://w3id.org/2025/arso#CapabilityGeneralizedByRel> a owl:Class ;
    rdfs:comment "RelationshipElement CapabilityGeneralizedBy — first: this capability (to be generalized); second: a more general capability." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/RelationshipElement> .

<https://w3id.org/2025/arso#ComposedOfContainerSMC> a owl:Class ;
    rdfs:comment "SMC ComposedOfContainer — one composition record; must contain at least 2 CapabilityComposedOf relationships." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/SubmodelElementCollection> .

<https://w3id.org/2025/arso#ConstraintHasPropertyRel> a owl:Class ;
    rdfs:comment "RelationshipElement ConstraintHasProperty — first: PropertyConstraint; second: Property from a PropertyContainer." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/RelationshipElement> .

<https://w3id.org/2025/arso#EndpointBaseProperty> a owl:Class ;
    rdfs:comment "Property base (xs:anyURI) — base URI for all forms in this Interface." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/Property> .

<https://w3id.org/2025/arso#ErrorCodeProperty> a owl:Class ;
    rdfs:comment "Property ErrorCode (xs:integer) — numeric error code identifying this error." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/Property> .

<https://w3id.org/2025/arso#ExternalDescriptorFile> a owl:Class ;
    rdfs:comment "File within ExternalDescriptor — path to an external TD document." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/File> .

<https://w3id.org/2025/arso#GuidelineForConformityDeclarationProperty> a owl:Class ;
    rdfs:comment "Property GuidelineForConformityDeclaration (xs:string) — guideline/stipulation/legislation used for conformity determination. semanticId: 0173-1#02-AAO856#002. Mandatory within GuidelineSpecificPropertiesSMC." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/Property> .

<https://w3id.org/2025/arso#HrefProperty> a owl:Class ;
    rdfs:comment "Property href (xs:string) — target URI for this form." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/Property> .

<https://w3id.org/2025/arso#InterfaceTitleProperty> a owl:Class ;
    rdfs:comment "Property title (xs:string) — human-readable name of the Interface." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/Property> .

<https://w3id.org/2025/arso#ManufacturerNameMLP> a owl:Class ;
    rdfs:comment "MLP ManufacturerName — legally valid designation of the manufacturer. semanticId: 0112/2///61987#ABA565#009. Mandatory." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/MultiLanguageProperty> .

<https://w3id.org/2025/arso#ManufacturerProductDesignationMLP> a owl:Class ;
    rdfs:comment "MLP ManufacturerProductDesignation — short description of the product. semanticId: 0112/2///61987#ABA567#009. Mandatory." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/MultiLanguageProperty> .

<https://w3id.org/2025/arso#MarkingFileFile> a owl:Class ;
    rdfs:comment "File MarkingFile — conformity symbol image of the marking. semanticId: 0112/2///61987#ABO100#002. Mandatory within MarkingSMC." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/File> .

<https://w3id.org/2025/arso#MarkingNameProperty> a owl:Class ;
    rdfs:comment "Property MarkingName (xs:string) — common name of the marking (preferably IRDI from IEC CDD or ECLASS). semanticId: 0112/2///61987#ABA231#009. Mandatory within MarkingSMC." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/Property> .

<https://w3id.org/2025/arso#OrderCodeProperty> a owl:Class ;
    rdfs:comment "Property OrderCodeOfManufacturer (xs:string) — unique order identifier. semanticId: 0112/2///61987#ABA950#008. Mandatory (changed from optional in v2)." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/Property> .

<https://w3id.org/2025/arso#ParameterEntrySMC> a owl:Class ;
    rdfs:comment "A parameter entry within the Parameters submodel." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/SubmodelElementCollection> .

<https://w3id.org/2025/arso#PropertyContainerSMC> a owl:Class ;
    rdfs:comment "SMC PropertyContainer — holds one CapabilityPropertyType instance plus SameProperty and PropertyComment." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/SubmodelElementCollection> .

<https://w3id.org/2025/arso#SchemeProperty> a owl:Class ;
    rdfs:comment "Property scheme (xs:string) — security scheme type identifier (nosec, basic, apikey, bearer, psk, digest, oauth2, combo, auto)." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/Property> .

<https://w3id.org/2025/arso#SecuritySML> a owl:Class ;
    rdfs:comment "SML security — list of active security scheme names (xs:string) referencing securityDefinitions." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/SubmodelElementList> .

<https://w3id.org/2025/arso#SkillDisabledProperty> a owl:Class ;
    rdfs:comment "Property Disabled (xs:boolean) — whether this skill is currently disabled." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/Property> .

<https://w3id.org/2025/arso#SkillErrorsSMC> a owl:Class ;
    rdfs:comment "SMC Errors — mandatory container for skill-specific Error entries. Always present, may be empty." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/SubmodelElementCollection> .

<https://w3id.org/2025/arso#SkillModesSMC> a owl:Class ;
    rdfs:comment "SMC Modes — mandatory container for Mode entries within a Skill. Always present, may be empty." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/SubmodelElementCollection> .

<https://w3id.org/2025/arso#SkillParametersSMC> a owl:Class ;
    rdfs:comment "SMC Parameters — mandatory container for skill parameter elements. Always present, may be empty." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/SubmodelElementCollection> .

<https://w3id.org/2025/arso#SkillUsesSMC> a owl:Class ;
    rdfs:comment "SMC Uses — optional container for references to capabilities used by this skill." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/SubmodelElementCollection> .

<https://w3id.org/2025/arso#TechnicalImageFile> a owl:Class ;
    rdfs:comment "File ImageFile — pictorial representation of the product." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/File> .

<https://w3id.org/2025/arso#TechnicalManufacturerArticleNumberProperty> a owl:Class ;
    rdfs:comment "Property ManufacturerArticleNumber (xs:string) — unique product identifier of the manufacturer." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/Property> .

<https://w3id.org/2025/arso#TechnicalManufacturerNameMLP> a owl:Class ;
    rdfs:comment "MLP ManufacturerName — legally valid designation of the manufacturer." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/MultiLanguageProperty> .

<https://w3id.org/2025/arso#TechnicalManufacturerOrderCodeProperty> a owl:Class ;
    rdfs:comment "Property ManufacturerOrderCode (xs:string) — unique code used for ordering." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/Property> .

<https://w3id.org/2025/arso#TechnicalManufacturerProductDesignationMLP> a owl:Class ;
    rdfs:comment "MLP ManufacturerProductDesignation — short description of the product." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/MultiLanguageProperty> .

<https://w3id.org/2025/arso#TechnicalTextStatementMLP> a owl:Class ;
    rdfs:comment "MLP TextStatement — note or explanation about the product." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/MultiLanguageProperty> .

<https://w3id.org/2025/arso#TechnicalValidDateProperty> a owl:Class ;
    rdfs:comment "Property ValidDate (xs:date) — validity date for the further information entry." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/Property> .

<https://w3id.org/2025/arso#TransitionConstrainedByRel> a owl:Class ;
    rdfs:comment "RelationshipElement TransitionConstrainedBy — first: constrained Capability; second: constraining Capability from another CapabilityContainer." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/RelationshipElement> .

<https://w3id.org/2025/arso#URIOfTheProductProperty> a owl:Class ;
    rdfs:comment "Property URIOfTheProduct (xs:anyURI) — unique global identification of the product instance. semanticId: 0112/2///61987#ABN590#002. Mandatory (cardinality 1) in v3.0." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/Property> .

<https://w3id.org/2025/arso#hasAIDSubmodel> a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:range <https://w3id.org/2025/arso#AIDSubmodel> ;
    rdfs:subPropertyOf <https://w3id.org/2025/arso#hasSubmodel> .

<https://w3id.org/2025/arso#hasCapabilitiesSubmodel> a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:range <https://w3id.org/2025/arso#CapabilitiesSubmodel> ;
    rdfs:subPropertyOf <https://w3id.org/2025/arso#hasSubmodel> .

<https://w3id.org/2025/arso#hasDigitalNameplateSubmodel> a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:range <https://w3id.org/2025/arso#DigitalNameplateSubmodel> ;
    rdfs:subPropertyOf <https://w3id.org/2025/arso#hasSubmodel> .

<https://w3id.org/2025/arso#hasHierarchicalStructuresSubmodel> a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:range <https://w3id.org/2025/arso#HierarchicalStructuresSubmodel> ;
    rdfs:subPropertyOf <https://w3id.org/2025/arso#hasSubmodel> .

<https://w3id.org/2025/arso#hasOperationalDataSubmodel> a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:range <https://w3id.org/2025/arso#OperationalDataSubmodel> ;
    rdfs:subPropertyOf <https://w3id.org/2025/arso#hasSubmodel> .

<https://w3id.org/2025/arso#hasParametersSubmodel> a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:range <https://w3id.org/2025/arso#ParametersSubmodel> ;
    rdfs:subPropertyOf <https://w3id.org/2025/arso#hasSubmodel> .

<https://w3id.org/2025/arso#hasSkillsSubmodel> a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:range <https://w3id.org/2025/arso#SkillsSubmodel> ;
    rdfs:subPropertyOf <https://w3id.org/2025/arso#hasSubmodel> .

<http://www.w3id.org/hsu-aut/css#behaviorConformsTo> a owl:ObjectProperty ;
    rdfs:domain <http://www.w3id.org/hsu-aut/css#Resource>,
        <http://www.w3id.org/hsu-aut/css#Skill> ;
    rdfs:range <http://www.w3id.org/hsu-aut/css#StateMachine> .

<https://admin-shell.io/aas/3/1/DataSpecificationContent> a owl:Class ;
    rdfs:label "Data Specification Content"^^xsd:string ;
    rdfs:comment "Data specification content is part of a data specification template and defines which additional attributes shall be added to the element instance that references the data specification template and meta information about the template itself."@en .

<https://admin-shell.io/aas/3/1/DataTypeDefXsd/Decimal> a <https://admin-shell.io/aas/3/1/DataTypeDefXsd> ;
    rdfs:label "Decimal"^^xsd:string .

<https://admin-shell.io/aas/3/1/EntityType/SelfManagedEntity> a <https://admin-shell.io/aas/3/1/EntityType> ;
    rdfs:label "Self Managed Entity"^^xsd:string ;
    rdfs:comment "Self-Managed Entities have their own AAS but can be part of the bill of material of a composite self-managed entity."@en .

<https://w3id.org/2025/arso#representsResource> a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:comment "The CSS Resource this AAS represents." ;
    rdfs:domain <https://admin-shell.io/aas/3/1/AssetAdministrationShell> ;
    rdfs:range <http://www.w3id.org/hsu-aut/css#Resource> ;
    owl:inverseOf <https://w3id.org/2025/arso#hasAAS> .

<http://www.w3id.org/hsu-aut/css#Constraint> a owl:Class ;
    rdfs:comment """Condition imposed on a capability that further details its applicability. \r
\r
Notes:\r
- A capability constraint can be formulated as one of the following three constraint types:\r
▪ A precondition, i.e., a condition that must hold before a function can be executed.\r
▪ A postcondition, i.e., a condition that must hold after a function has been executed.\r
▪ An invariant, i.e., a condition that must hold during the execution of a\r
function.\r
- A capability constraint restricts the values of the properties associated with the respective capability.\r
- A capability constraint can involve one or more properties""" ;
    owl:disjointWith <http://www.w3id.org/hsu-aut/css#Resource>,
        <http://www.w3id.org/hsu-aut/css#Service>,
        <http://www.w3id.org/hsu-aut/css#ServiceOffer>,
        <http://www.w3id.org/hsu-aut/css#ServiceProvider>,
        <http://www.w3id.org/hsu-aut/css#ServiceRequester>,
        <http://www.w3id.org/hsu-aut/css#Skill>,
        <http://www.w3id.org/hsu-aut/css#SkillInterface>,
        <http://www.w3id.org/hsu-aut/css#SkillParameter> .

<http://www.w3id.org/hsu-aut/css#isRealizedBy> a owl:ObjectProperty ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( <http://www.w3id.org/hsu-aut/css#Capability> <http://www.w3id.org/hsu-aut/css#Property> ) ] ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( <http://www.w3id.org/hsu-aut/css#Skill> <http://www.w3id.org/hsu-aut/css#SkillParameter> ) ] .

<http://www.w3id.org/hsu-aut/css#provides> a owl:ObjectProperty ;
    rdfs:domain <http://www.w3id.org/hsu-aut/css#Resource> .

<https://admin-shell.io/aas/3/1/Direction> a owl:Class ;
    rdfs:label "Direction"^^xsd:string ;
    rdfs:comment "Direction"@en ;
    owl:oneOf ( <https://admin-shell.io/aas/3/1/Direction/Input> <https://admin-shell.io/aas/3/1/Direction/Output> ) .

<https://admin-shell.io/aas/3/1/Entity/entityType> a owl:ObjectProperty ;
    rdfs:label "has entity type"^^xsd:string ;
    rdfs:comment "Describes whether the entity is a co-managed entity or a self-managed entity."@en ;
    rdfs:domain <https://admin-shell.io/aas/3/1/Entity> ;
    rdfs:range <https://admin-shell.io/aas/3/1/EntityType> .

<https://admin-shell.io/aas/3/1/Entity/globalAssetId> a owl:DatatypeProperty ;
    rdfs:label "has global asset ID"^^xsd:string ;
    rdfs:comment "Global identifier of the asset the entity is representing."@en ;
    rdfs:domain <https://admin-shell.io/aas/3/1/Entity> ;
    rdfs:range xsd:string .

<https://admin-shell.io/aas/3/1/HasSemantics/semanticId> a owl:ObjectProperty ;
    rdfs:label "has semantic ID"^^xsd:string ;
    rdfs:comment "Identifier of the semantic definition of the element. It is called semantic ID of the element or also main semantic ID of the element."@en ;
    rdfs:domain <https://admin-shell.io/aas/3/1/HasSemantics> ;
    rdfs:range <https://admin-shell.io/aas/3/1/Reference> .

<https://admin-shell.io/aas/3/1/LangStringTextType> a owl:Class ;
    rdfs:label "Lang String Text Type"^^xsd:string ;
    rdfs:comment "String with length 1023 maximum and minimum 1 characters and with language tags"@en ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/AbstractLangString> .

<https://admin-shell.io/aas/3/1/ModellingKind> a owl:Class ;
    rdfs:label "Modelling Kind"^^xsd:string ;
    rdfs:comment "Enumeration for denoting whether an element is a template or an instance."@en ;
    owl:oneOf ( <https://admin-shell.io/aas/3/1/ModellingKind/Instance> <https://admin-shell.io/aas/3/1/ModellingKind/Template> ) .

<https://admin-shell.io/aas/3/1/Property/valueType> a owl:ObjectProperty ;
    rdfs:label "has value type"^^xsd:string ;
    rdfs:comment "Data type of the value"@en ;
    rdfs:domain <https://admin-shell.io/aas/3/1/Property> ;
    rdfs:range <https://admin-shell.io/aas/3/1/DataTypeDefXsd> .

<https://admin-shell.io/aas/3/1/ReferenceTypes> a owl:Class ;
    rdfs:label "Reference Types"^^xsd:string ;
    rdfs:comment "Reference types"@en ;
    owl:oneOf ( <https://admin-shell.io/aas/3/1/ReferenceTypes/ExternalReference> <https://admin-shell.io/aas/3/1/ReferenceTypes/ModelReference> ) .

<https://admin-shell.io/aas/3/1/StateOfEvent> a owl:Class ;
    rdfs:label "State Of Event"^^xsd:string ;
    rdfs:comment "State of an event"@en ;
    owl:oneOf ( <https://admin-shell.io/aas/3/1/StateOfEvent/Off> <https://admin-shell.io/aas/3/1/StateOfEvent/On> ) .

<https://w3id.org/2025/arso#TechnicalPropertyAreaSMC> a owl:Class ;
    rdfs:comment "SMC TechnicalPropertyArea — one technical property area entry." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/SubmodelElementCollection> .

<https://w3id.org/2025/arso#TechnicalSpecificDescriptionSMC> a owl:Class ;
    rdfs:comment "SMC SpecificDescription — one specific description entry." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/SubmodelElementCollection> .

<https://w3id.org/2025/arso#hasAAS> a owl:ObjectProperty ;
    rdfs:comment "Connects a CSS Resource to the AAS that represents it." ;
    rdfs:domain <http://www.w3id.org/hsu-aut/css#Resource> ;
    rdfs:range <https://admin-shell.io/aas/3/1/AssetAdministrationShell> .

<http://www.w3id.org/hsu-aut/css#exposes> a owl:ObjectProperty ;
    rdfs:domain <http://www.w3id.org/hsu-aut/css#SkillInterface> ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( <http://www.w3id.org/hsu-aut/css#SkillParameter> <http://www.w3id.org/hsu-aut/css#SkillTrigger> <http://www.w3id.org/hsu-aut/css#StateMachine> ) ] .

<https://admin-shell.io/aas/3/1/EntityType> a owl:Class ;
    rdfs:label "Entity Type"^^xsd:string ;
    rdfs:comment "Enumeration for denoting whether an entity is a self-managed entity or a co-managed entity."@en ;
    owl:oneOf ( <https://admin-shell.io/aas/3/1/EntityType/CoManagedEntity> <https://admin-shell.io/aas/3/1/EntityType/SelfManagedEntity> ) .

<https://admin-shell.io/aas/3/1/QualifierKind> a owl:Class ;
    rdfs:label "Qualifier Kind"^^xsd:string ;
    rdfs:comment "Enumeration for kinds of qualifiers."@en ;
    owl:oneOf ( <https://admin-shell.io/aas/3/1/QualifierKind/ConceptQualifier> <https://admin-shell.io/aas/3/1/QualifierKind/TemplateQualifier> <https://admin-shell.io/aas/3/1/QualifierKind/ValueQualifier> ) .

<https://admin-shell.io/aas/3/1/AssetKind> a owl:Class ;
    rdfs:label "Asset Kind"^^xsd:string ;
    rdfs:comment "Enumeration for denoting whether an asset is a type asset or an instance asset."@en ;
    owl:oneOf ( <https://admin-shell.io/aas/3/1/AssetKind/Instance> <https://admin-shell.io/aas/3/1/AssetKind/NotApplicable> <https://admin-shell.io/aas/3/1/AssetKind/Role> <https://admin-shell.io/aas/3/1/AssetKind/Type> ) .

<https://admin-shell.io/aas/3/1/Entity/statements> a owl:ObjectProperty ;
    rdfs:label "has statements"^^xsd:string ;
    rdfs:comment "Describes statements applicable to the entity by a set of submodel elements, typically with a qualified value."@en ;
    rdfs:domain <https://admin-shell.io/aas/3/1/Entity> ;
    rdfs:range <https://admin-shell.io/aas/3/1/SubmodelElement> .

<http://www.w3id.org/hsu-aut/css#Product> a owl:Class ;
    rdfs:comment """Physical object being used as an input or created as an output of a production process.\r
\r
Notes:\r
- The term Product may be used for objects in various states of manufacturing and may be seen as a generic term for raw materials, work in process and finished goods. Consumable supplies such as fuel, lubricants or cleaning agents may also be regarded as products. Furthermore, both purchased parts as well as parts manufactured in-house may be regarded as products.\r
- Besides the actual product, there can be additional artifacts related to that product that are created and used in different life cycle phases to specify the product.\r
▪ 3D/CAD models\r
▪ specifications\r
▪ BOM\r
- A Service Requester may use these additional artifacts to formulate requirements against products.""" ;
    owl:disjointWith <http://www.w3id.org/hsu-aut/css#Service>,
        <http://www.w3id.org/hsu-aut/css#ServiceOffer>,
        <http://www.w3id.org/hsu-aut/css#ServiceProvider>,
        <http://www.w3id.org/hsu-aut/css#ServiceRequester>,
        <http://www.w3id.org/hsu-aut/css#Skill>,
        <http://www.w3id.org/hsu-aut/css#SkillInterface>,
        <http://www.w3id.org/hsu-aut/css#SkillParameter> .

<https://admin-shell.io/aas/3/1/DataElement> a owl:Class ;
    rdfs:label "Data Element"^^xsd:string ;
    rdfs:comment "A data element is a submodel element that is not further composed out of other submodel elements."@en ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/SubmodelElement> .

<https://admin-shell.io/aas/3/1/Property/value> a owl:DatatypeProperty ;
    rdfs:label "has value"^^xsd:string ;
    rdfs:comment "The value of the property instance."@en ;
    rdfs:domain <https://admin-shell.io/aas/3/1/Property> ;
    rdfs:range xsd:string .

<https://admin-shell.io/aas/3/1/> a owl:Ontology ;
    rdfs:comment "This ontology represents the data model for the Asset Administration Shell according to the specification version V3.1."@en ;
    rdfs:isDefinedBy <https://admin-shell.io/aas/3/1/> ;
    owl:versionInfo "V3.1" .

<http://www.w3id.org/hsu-aut/css#ServiceOffer> a owl:Class ;
    rdfs:comment """Proposal for a binding contract from the Service Provider to execute one or more particular services that a ServiceRequester can receive and accept.\r
\r
Notes:\r
- A ServiceOffer should determine the commercial aspects of the service provision\r
and may remain valid for a certain period of time.\r
- An Offer may consist of partial offers proposed by different service providers""" ;
    owl:disjointWith <http://www.w3id.org/hsu-aut/css#ServiceProvider>,
        <http://www.w3id.org/hsu-aut/css#ServiceRequester>,
        <http://www.w3id.org/hsu-aut/css#Skill>,
        <http://www.w3id.org/hsu-aut/css#SkillInterface>,
        <http://www.w3id.org/hsu-aut/css#SkillParameter>,
        <http://www.w3id.org/hsu-aut/css#StateMachine> .

<https://admin-shell.io/aas/3/1/SubmodelElementList/value> a owl:ObjectProperty ;
    rdfs:label "has value"^^xsd:string ;
    rdfs:comment "Submodel element contained in the list."@en ;
    rdfs:domain <https://admin-shell.io/aas/3/1/SubmodelElementList> ;
    rdfs:range <https://admin-shell.io/aas/3/1/SubmodelElement> .

<https://admin-shell.io/aas/3/1/AasSubmodelElements> a owl:Class ;
    rdfs:label "AAS Submodel Elements"^^xsd:string ;
    rdfs:comment "Enumeration of all possible elements of a 'SubmodelElementList'."@en ;
    owl:oneOf ( <https://admin-shell.io/aas/3/1/AasSubmodelElements/AnnotatedRelationshipElement> <https://admin-shell.io/aas/3/1/AasSubmodelElements/BasicEventElement> <https://admin-shell.io/aas/3/1/AasSubmodelElements/Blob> <https://admin-shell.io/aas/3/1/AasSubmodelElements/Capability> <https://admin-shell.io/aas/3/1/AasSubmodelElements/DataElement> <https://admin-shell.io/aas/3/1/AasSubmodelElements/Entity> <https://admin-shell.io/aas/3/1/AasSubmodelElements/EventElement> <https://admin-shell.io/aas/3/1/AasSubmodelElements/File> <https://admin-shell.io/aas/3/1/AasSubmodelElements/MultiLanguageProperty> <https://admin-shell.io/aas/3/1/AasSubmodelElements/Operation> <https://admin-shell.io/aas/3/1/AasSubmodelElements/Property> <https://admin-shell.io/aas/3/1/AasSubmodelElements/Range> <https://admin-shell.io/aas/3/1/AasSubmodelElements/ReferenceElement> <https://admin-shell.io/aas/3/1/AasSubmodelElements/RelationshipElement> <https://admin-shell.io/aas/3/1/AasSubmodelElements/SubmodelElement> <https://admin-shell.io/aas/3/1/AasSubmodelElements/SubmodelElementCollection> <https://admin-shell.io/aas/3/1/AasSubmodelElements/SubmodelElementList> ) .

<https://admin-shell.io/aas/3/1/DataTypeIec61360> a owl:Class ;
    rdfs:label "Data Type IEC 61360"^^xsd:string ;
    owl:oneOf ( <https://admin-shell.io/aas/3/1/DataTypeIec61360/Blob> <https://admin-shell.io/aas/3/1/DataTypeIec61360/Boolean> <https://admin-shell.io/aas/3/1/DataTypeIec61360/Date> <https://admin-shell.io/aas/3/1/DataTypeIec61360/File> <https://admin-shell.io/aas/3/1/DataTypeIec61360/Html> <https://admin-shell.io/aas/3/1/DataTypeIec61360/IntegerCount> <https://admin-shell.io/aas/3/1/DataTypeIec61360/IntegerCurrency> <https://admin-shell.io/aas/3/1/DataTypeIec61360/IntegerMeasure> <https://admin-shell.io/aas/3/1/DataTypeIec61360/Irdi> <https://admin-shell.io/aas/3/1/DataTypeIec61360/Iri> <https://admin-shell.io/aas/3/1/DataTypeIec61360/Rational> <https://admin-shell.io/aas/3/1/DataTypeIec61360/RationalMeasure> <https://admin-shell.io/aas/3/1/DataTypeIec61360/RealCount> <https://admin-shell.io/aas/3/1/DataTypeIec61360/RealCurrency> <https://admin-shell.io/aas/3/1/DataTypeIec61360/RealMeasure> <https://admin-shell.io/aas/3/1/DataTypeIec61360/String> <https://admin-shell.io/aas/3/1/DataTypeIec61360/StringTranslatable> <https://admin-shell.io/aas/3/1/DataTypeIec61360/Time> <https://admin-shell.io/aas/3/1/DataTypeIec61360/Timestamp> ) .

<http://www.w3id.org/hsu-aut/css#SkillParameter> a owl:Class ;
    rdfs:comment """Data unit to configure, control and monitor the execution of a skill.\r
\r
Notes:\r
- Skill parameters might be used as in- /output parameters\r
- Skill parameters might be used as results\r
- Skill parameters might have a relation or be equivalent to capability properties""" ;
    owl:disjointWith <http://www.w3id.org/hsu-aut/css#StateMachine> .

<https://admin-shell.io/aas/3/1/KeyTypes> a owl:Class ;
    rdfs:label "Key Types"^^xsd:string ;
    rdfs:comment "Enumeration of different key value types within a key."@en ;
    owl:oneOf ( <https://admin-shell.io/aas/3/1/KeyTypes/AnnotatedRelationshipElement> <https://admin-shell.io/aas/3/1/KeyTypes/AssetAdministrationShell> <https://admin-shell.io/aas/3/1/KeyTypes/BasicEventElement> <https://admin-shell.io/aas/3/1/KeyTypes/Blob> <https://admin-shell.io/aas/3/1/KeyTypes/Capability> <https://admin-shell.io/aas/3/1/KeyTypes/ConceptDescription> <https://admin-shell.io/aas/3/1/KeyTypes/DataElement> <https://admin-shell.io/aas/3/1/KeyTypes/Entity> <https://admin-shell.io/aas/3/1/KeyTypes/EventElement> <https://admin-shell.io/aas/3/1/KeyTypes/File> <https://admin-shell.io/aas/3/1/KeyTypes/FragmentReference> <https://admin-shell.io/aas/3/1/KeyTypes/GlobalReference> <https://admin-shell.io/aas/3/1/KeyTypes/Identifiable> <https://admin-shell.io/aas/3/1/KeyTypes/MultiLanguageProperty> <https://admin-shell.io/aas/3/1/KeyTypes/Operation> <https://admin-shell.io/aas/3/1/KeyTypes/Property> <https://admin-shell.io/aas/3/1/KeyTypes/Range> <https://admin-shell.io/aas/3/1/KeyTypes/Referable> <https://admin-shell.io/aas/3/1/KeyTypes/ReferenceElement> <https://admin-shell.io/aas/3/1/KeyTypes/RelationshipElement> <https://admin-shell.io/aas/3/1/KeyTypes/Submodel> <https://admin-shell.io/aas/3/1/KeyTypes/SubmodelElement> <https://admin-shell.io/aas/3/1/KeyTypes/SubmodelElementCollection> <https://admin-shell.io/aas/3/1/KeyTypes/SubmodelElementList> ) .

<https://w3id.org/2025/arso#hasSubmodel> a owl:ObjectProperty ;
    rdfs:comment "Direct link from AAS to a submodel instance (bypassing Reference indirection)." ;
    rdfs:domain <https://admin-shell.io/aas/3/1/AssetAdministrationShell> ;
    rdfs:range <https://admin-shell.io/aas/3/1/Submodel> .

<https://admin-shell.io/aas/3/1/Submodel/submodelElements> a owl:ObjectProperty ;
    rdfs:label "has submodel elements"^^xsd:string ;
    rdfs:comment "A submodel consists of zero or more submodel elements."@en ;
    rdfs:domain <https://admin-shell.io/aas/3/1/Submodel> ;
    rdfs:range <https://admin-shell.io/aas/3/1/SubmodelElement> .

<https://admin-shell.io/aas/3/1/DataTypeDefXsd> a owl:Class ;
    rdfs:label "Data Type Def XSD"^^xsd:string ;
    rdfs:comment "Enumeration listing all XSD anySimpleTypes"@en ;
    owl:oneOf ( <https://admin-shell.io/aas/3/1/DataTypeDefXsd/AnyUri> <https://admin-shell.io/aas/3/1/DataTypeDefXsd/Base64Binary> <https://admin-shell.io/aas/3/1/DataTypeDefXsd/Boolean> <https://admin-shell.io/aas/3/1/DataTypeDefXsd/Byte> <https://admin-shell.io/aas/3/1/DataTypeDefXsd/Date> <https://admin-shell.io/aas/3/1/DataTypeDefXsd/DateTime> <https://admin-shell.io/aas/3/1/DataTypeDefXsd/Decimal> <https://admin-shell.io/aas/3/1/DataTypeDefXsd/Double> <https://admin-shell.io/aas/3/1/DataTypeDefXsd/Duration> <https://admin-shell.io/aas/3/1/DataTypeDefXsd/Float> <https://admin-shell.io/aas/3/1/DataTypeDefXsd/GDay> <https://admin-shell.io/aas/3/1/DataTypeDefXsd/GMonth> <https://admin-shell.io/aas/3/1/DataTypeDefXsd/GMonthDay> <https://admin-shell.io/aas/3/1/DataTypeDefXsd/GYear> <https://admin-shell.io/aas/3/1/DataTypeDefXsd/GYearMonth> <https://admin-shell.io/aas/3/1/DataTypeDefXsd/HexBinary> <https://admin-shell.io/aas/3/1/DataTypeDefXsd/Int> <https://admin-shell.io/aas/3/1/DataTypeDefXsd/Integer> <https://admin-shell.io/aas/3/1/DataTypeDefXsd/Long> <https://admin-shell.io/aas/3/1/DataTypeDefXsd/NegativeInteger> <https://admin-shell.io/aas/3/1/DataTypeDefXsd/NonNegativeInteger> <https://admin-shell.io/aas/3/1/DataTypeDefXsd/NonPositiveInteger> <https://admin-shell.io/aas/3/1/DataTypeDefXsd/PositiveInteger> <https://admin-shell.io/aas/3/1/DataTypeDefXsd/Short> <https://admin-shell.io/aas/3/1/DataTypeDefXsd/String> <https://admin-shell.io/aas/3/1/DataTypeDefXsd/Time> <https://admin-shell.io/aas/3/1/DataTypeDefXsd/UnsignedByte> <https://admin-shell.io/aas/3/1/DataTypeDefXsd/UnsignedInt> <https://admin-shell.io/aas/3/1/DataTypeDefXsd/UnsignedLong> <https://admin-shell.io/aas/3/1/DataTypeDefXsd/UnsignedShort> ) .

<https://admin-shell.io/aas/3/1/SubmodelElement> a owl:Class ;
    rdfs:label "Submodel Element"^^xsd:string ;
    rdfs:comment "A submodel element is an element suitable for the description and differentiation of assets."@en ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/HasDataSpecification>,
        <https://admin-shell.io/aas/3/1/HasSemantics>,
        <https://admin-shell.io/aas/3/1/Qualifiable>,
        <https://admin-shell.io/aas/3/1/Referable> .

<https://admin-shell.io/aas/3/1/SubmodelElementCollection/value> a owl:ObjectProperty ;
    rdfs:label "has value"^^xsd:string ;
    rdfs:comment "Submodel element contained in the collection."@en ;
    rdfs:domain <https://admin-shell.io/aas/3/1/SubmodelElementCollection> ;
    rdfs:range <https://admin-shell.io/aas/3/1/SubmodelElement> .

[] a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://w3id.org/2025/arso#hasSubmodel> ;
            owl:someValuesFrom <https://w3id.org/2025/arso#AIDSubmodel> ] ;
    owl:intersectionOf ( <https://admin-shell.io/aas/3/1/AssetAdministrationShell> [ a owl:Restriction ;
                owl:onProperty <https://w3id.org/2025/arso#hasSubmodel> ;
                owl:someValuesFrom <https://w3id.org/2025/arso#SkillsSubmodel> ] ) .

[] a owl:Class ;
