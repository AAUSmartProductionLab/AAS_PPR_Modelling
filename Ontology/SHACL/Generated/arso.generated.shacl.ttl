        <https://admin-shell.io/aas/3/1/Qualifier-https___admin-shell.io_aas_3_1_Qualifier_valueId>,
        <https://admin-shell.io/aas/3/1/Qualifier-https___admin-shell.io_aas_3_1_Qualifier_valueType> .

<https://admin-shell.io/aas/3/1/Range> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:label "Range"^^xsd:string ;
