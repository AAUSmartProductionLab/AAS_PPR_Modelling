<https://w3id.org/2025/arso> a owl:Ontology ;
    rdfs:comment """ARSO v0.4 — Domain extension ontology for Resource AAS.\r
\r
  This ontology:\r
    - imports the official AAS v3.1 ontology for structural validation\r
    - imports per-submodel modules that define element types and internal constraints\r
    - defines the CSS Resource ↔ AAS link and cross-submodel dependencies here\r
    - uses AAS properties (submodelElements, value, etc.) for containment\r
    - adds arso: properties only for cross-submodel dependency checks\r
\r
  Structural/formatting validation is handled by the AAS ontology + SHACL.\r
  This ontology adds ONLY domain-specific constraints on top.""" ;
    owl:imports <http://www.w3id.org/hsu-aut/css>,
        <https://admin-shell.io/aas/3/1/>,
        <https://w3id.org/2025/arso/modules/aid>,
        <https://w3id.org/2025/arso/modules/capabilities>,
        <https://w3id.org/2025/arso/modules/control-component>,
        <https://w3id.org/2025/arso/modules/hierarchical-structures>,
        <https://w3id.org/2025/arso/modules/nameplate>,
        <https://w3id.org/2025/arso/modules/operational-data>,
        <https://w3id.org/2025/arso/modules/parameters>,
        <https://w3id.org/2025/arso/modules/technical-data> ;
    owl:versionIRI <https://w3id.org/2025/arso/0.4.0> .

<https://w3id.org/2025/arso#CapabilityCommentMLP> a owl:Class ;
    rdfs:comment "MLP CapabilityComment — individual human-readable comment for the capability." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/MultiLanguageProperty> .

<https://w3id.org/2025/arso#CapabilityComposedOfRel> a owl:Class ;
    rdfs:comment "RelationshipElement CapabilityComposedOf — first: composed capability; second: one of its sub-capabilities. Minimum 2 per ComposedOfContainer." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/RelationshipElement> .

<https://w3id.org/2025/arso#CapabilityRealizedByRel> a owl:Class ;
    rdfs:comment "RelationshipElement CapabilityRealizedBy — first: Capability in this SM; second: Skill in the Skills Submodel of the same AAS. Cross-SM enforcement via SPARQL SHACL." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/RelationshipElement> .

<https://w3id.org/2025/arso#CompanyLogoFile> a owl:Class ;
    rdfs:comment "File CompanyLogo — graphic mark representing the company/organisation/product. semanticId: 0112/2///61987#ABP463#001. Optional (0..1)." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/File> .

<https://w3id.org/2025/arso#ComposedOfCommentMLP> a owl:Class ;
    rdfs:comment "MLP ComposedOfComment — human-readable description of the composition." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/MultiLanguageProperty> .

<https://w3id.org/2025/arso#ConstraintSetSMC> a owl:Class ;
    rdfs:comment "SMC ConstraintSet — created when constraints on the capability exist. Must contain at least one PropertyConstraintContainer or TransitionConstraintContainer (SM-CapabilityDescription-2)." ;
    rdfs:subClassOf [ a owl:Class ;
            owl:unionOf ( [ a owl:Restriction ;
                        owl:onProperty <https://admin-shell.io/aas/3/1/SubmodelElementCollection/value> ;
                        owl:someValuesFrom <https://w3id.org/2025/arso#PropertyConstraintContainerSMC> ] [ a owl:Restriction ;
                        owl:onProperty <https://admin-shell.io/aas/3/1/SubmodelElementCollection/value> ;
                        owl:someValuesFrom <https://w3id.org/2025/arso#TransitionConstraintContainerSMC> ] ) ],
        <https://admin-shell.io/aas/3/1/SubmodelElementCollection> .

<https://w3id.org/2025/arso#ContentTypeProperty> a owl:Class ;
    rdfs:comment "Property contentType (xs:string) — default media type (e.g. application/json)." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/Property> .

<https://w3id.org/2025/arso#CountryOfOriginProperty> a owl:Class ;
