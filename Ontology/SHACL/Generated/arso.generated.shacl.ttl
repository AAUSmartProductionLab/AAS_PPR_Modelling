<https://w3id.org/2025/arso#PropertyCommentMLP> a owl:Class ;
    rdfs:comment "MLP PropertyComment — general human-readable description of the property." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/MultiLanguageProperty> .

<https://w3id.org/2025/arso#ResourceAAS> a owl:Class ;
    rdfs:label "Resource AAS" ;
    rdfs:comment "Asset Administration Shell that represents a CSS Resource (machine/equipment). Counterpart of apso:ProductAAS; the JSON-to-RDF projection types resource shells with this class." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/AssetAdministrationShell> .

<https://w3id.org/2025/arso#SameAsRelationship> a owl:Class ;
    rdfs:comment "RelationshipElement SameAs — links two entities representing the same asset, within or across submodels. Both first and second must reference an EntryNodeEntity or NodeEntity." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/RelationshipElement> .

<https://w3id.org/2025/arso#SamePropertyRel> a owl:Class ;
    rdfs:comment "RelationshipElement SameProperty — links the property in this PropertyContainer (first) to an identical property in another Submodel or external source (second)." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/RelationshipElement> .

<https://w3id.org/2025/arso#SerialNumberProperty> a owl:Class ;
    rdfs:comment "Property SerialNumber (xs:string) — unique identifier for the manufactured device. semanticId: 0112/2///61987#ABA951#009. Optional (0..1)." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/Property> .

<https://w3id.org/2025/arso#SkillModeSMC> a owl:Class ;
    rdfs:comment "SMC {mode_name} — a named execution mode of a skill." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/SubmodelElementCollection> .

<https://w3id.org/2025/arso#SoftwareVersionProperty> a owl:Class ;
    rdfs:comment "Property SoftwareVersion (xs:string) — version of software used by the device. semanticId: 0112/2///61987#ABA601#008. Optional (0..1)." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/Property> .

<https://w3id.org/2025/arso#TechnicalCompanyLogoFile> a owl:Class ;
    rdfs:comment "File CompanyLogo — company logo image." ;
