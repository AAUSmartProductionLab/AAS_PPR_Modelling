<https://w3id.org/2025/arso/modules/capabilities> a owl:Ontology ;
    rdfs:comment """ARSO module: Capability Description (IDTA 02020-1-0).\r
\r
  Submodel semanticId: https://admin-shell.io/idta/SubmodelTemplate/CapabilityDescription/1/0\r
  Cross-submodel: CapabilityRealizedBy.second must reference a Skill in the Skills SM of the same AAS (enforced via SPARQL SHACL).""" ;
    owl:imports <https://admin-shell.io/aas/3/1/> .

<https://w3id.org/2025/arso/modules/control-component> a owl:Ontology ;
