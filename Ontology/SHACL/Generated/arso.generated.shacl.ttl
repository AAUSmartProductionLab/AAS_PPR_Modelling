@prefix ns1: <http://datashapes.org/dash#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://www.w3id.org/hsu-aut/css#Capability> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:comment """Implementation-independent specification of a function in industrial production to achieve an effect in the physical or virtual world.\r
\r
Notes:\r
- A capability can be restricted by constraints.\r
- A capability can be specified by capability properties.\r
- A capability can be realized by skills""" ;
    owl:disjointWith <http://www.w3id.org/hsu-aut/css#Resource>,
        <http://www.w3id.org/hsu-aut/css#ServiceOffer>,
        <http://www.w3id.org/hsu-aut/css#ServiceProvider>,
        <http://www.w3id.org/hsu-aut/css#ServiceRequester>,
        <http://www.w3id.org/hsu-aut/css#Skill>,
        <http://www.w3id.org/hsu-aut/css#SkillInterface>,
        <http://www.w3id.org/hsu-aut/css#SkillParameter> ;
    sh:property <http://www.w3id.org/hsu-aut/css#Capability-isRealizedBy>,
        <http://www.w3id.org/hsu-aut/css#Capability-isRealizedBySkill>,
        <http://www.w3id.org/hsu-aut/css#Capability-isRestrictedBy>,
        <http://www.w3id.org/hsu-aut/css#Capability-isSpecifiedBy> .

<http://www.w3id.org/hsu-aut/css#Process> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:comment """Production-relevant activity at any level of granularity that might affect materials and is performed by resources.\r
\r
Notes:\r
- In general, a process can be decomposed into sub-processes or single activities.\r
- A process can require capabilities to express that any suitable resource used for\r
performing this process needs to provide compatible capabilities.\r
- A process step relates to materials that constitute either input or output for the processing in this step""" ;
    owl:disjointWith <http://www.w3id.org/hsu-aut/css#Resource>,
        <http://www.w3id.org/hsu-aut/css#Service>,
        <http://www.w3id.org/hsu-aut/css#ServiceOffer>,
        <http://www.w3id.org/hsu-aut/css#ServiceProvider>,
        <http://www.w3id.org/hsu-aut/css#Skill>,
        <http://www.w3id.org/hsu-aut/css#SkillInterface>,
        <http://www.w3id.org/hsu-aut/css#SkillParameter> ;
    sh:property <http://www.w3id.org/hsu-aut/css#Process-hasInput>,
        <http://www.w3id.org/hsu-aut/css#Process-hasOutput>,
        <http://www.w3id.org/hsu-aut/css#Process-requiresCapability> .

<http://www.w3id.org/hsu-aut/css#Property> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:comment """Quality or characteristic inherent in or ascribed to any CSS model element\r
\r
Notes:\r
- Properties may be used to describe and differentiate all kinds of PPR entities (i.e., products, process steps, resources)\r
- Capabilities, services and offers are specified by properties in order to detail their description with regard to certain entities (e.g. products, process steps, resources)""" ;
    owl:disjointWith <http://www.w3id.org/hsu-aut/css#Resource>,
        <http://www.w3id.org/hsu-aut/css#Service>,
        <http://www.w3id.org/hsu-aut/css#ServiceOffer>,
        <http://www.w3id.org/hsu-aut/css#ServiceProvider>,
        <http://www.w3id.org/hsu-aut/css#ServiceRequester>,
        <http://www.w3id.org/hsu-aut/css#Skill>,
        <http://www.w3id.org/hsu-aut/css#SkillInterface> ;
    sh:property <http://www.w3id.org/hsu-aut/css#Property-isRealizedBy>,
        <http://www.w3id.org/hsu-aut/css#Property-isRealizedBySkillParameter> .

<http://www.w3id.org/hsu-aut/css#PropertyConstraint> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:comment "A PropertyConstraint is a constraint that determines the applicability of a Capability and that refers to one or more Properties of the same Capability (see Figure 15). An important aspect of PropertyConstraints is that they always refer to a single Capability and assume no knowledge of a sequence of Capabilities or dependencies between Capabilities." ;
    rdfs:subClassOf <http://www.w3id.org/hsu-aut/css#Constraint> ;
    sh:property <http://www.w3id.org/hsu-aut/css#PropertyConstraint-referencesProperty> .

<http://www.w3id.org/hsu-aut/css#Resource> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:comment """Entity capable of performing functions specified as Capabilities and potentially implemented as Skills.\r
\r
Notes\r
- A production resource may consist of hardware, software or both\r
- A production resource may only provide capabilities (i.e. when engineering a resource, for planning purposes) and may additionally provide skills for automatic execution of the specified function.\r
- A human becomes a Production Resource, if that person is able to perform a function specified as a capability.""" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass <https://admin-shell.io/aas/3/1/AssetAdministrationShell> ;
            owl:onProperty <https://w3id.org/2025/arso#hasAAS> ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ] ;
    owl:disjointWith <http://www.w3id.org/hsu-aut/css#Service>,
        <http://www.w3id.org/hsu-aut/css#ServiceOffer>,
        <http://www.w3id.org/hsu-aut/css#Skill>,
        <http://www.w3id.org/hsu-aut/css#SkillInterface>,
        <http://www.w3id.org/hsu-aut/css#SkillParameter>,
        <http://www.w3id.org/hsu-aut/css#StateMachine> ;
    sh:property <http://www.w3id.org/hsu-aut/css#Resource-behaviorConformsTo>,
        <http://www.w3id.org/hsu-aut/css#Resource-hasAAS>,
        <http://www.w3id.org/hsu-aut/css#Resource-provides>,
        <http://www.w3id.org/hsu-aut/css#Resource-providesCapability>,
        <http://www.w3id.org/hsu-aut/css#Resource-providesSkill> .

<http://www.w3id.org/hsu-aut/css#Service> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:comment """Description of the commercial aspects and means of provision of offered capabilities.\r
\r
Notes:\r
- The term “service” should be understood in the sense of economics and shall not be confused with e.g., web services.\r
- The capabilities and means of provisions are specified by properties\r
- A service is demanded by service requesters and provided by a service provider\r
- A service is an input for an offer proposed by""" ;
    owl:disjointWith <http://www.w3id.org/hsu-aut/css#ServiceOffer>,
        <http://www.w3id.org/hsu-aut/css#ServiceProvider>,
        <http://www.w3id.org/hsu-aut/css#ServiceRequester>,
        <http://www.w3id.org/hsu-aut/css#Skill>,
        <http://www.w3id.org/hsu-aut/css#SkillInterface>,
        <http://www.w3id.org/hsu-aut/css#SkillParameter>,
        <http://www.w3id.org/hsu-aut/css#StateMachine> ;
    sh:property <http://www.w3id.org/hsu-aut/css#Service-assures>,
        <http://www.w3id.org/hsu-aut/css#Service-isInputFor>,
        <http://www.w3id.org/hsu-aut/css#Service-isSpecifiedBy>,
        <http://www.w3id.org/hsu-aut/css#Service-offersUseOf> .

<http://www.w3id.org/hsu-aut/css#ServiceProvider> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:comment "Provides Services and can propose ServiceOffers to ServiceRequesters." ;
    owl:disjointWith <http://www.w3id.org/hsu-aut/css#Skill>,
        <http://www.w3id.org/hsu-aut/css#SkillInterface>,
        <http://www.w3id.org/hsu-aut/css#SkillParameter>,
        <http://www.w3id.org/hsu-aut/css#StateMachine> ;
    sh:property <http://www.w3id.org/hsu-aut/css#ServiceProvider-offers>,
        <http://www.w3id.org/hsu-aut/css#ServiceProvider-proposes> .

<http://www.w3id.org/hsu-aut/css#ServiceRequester> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:comment """Demands Services under particular commercial aspects by providing either a specification of\r
services or a specification of product requirements.""" ;
    owl:disjointWith <http://www.w3id.org/hsu-aut/css#Skill>,
        <http://www.w3id.org/hsu-aut/css#SkillInterface>,
        <http://www.w3id.org/hsu-aut/css#SkillParameter>,
        <http://www.w3id.org/hsu-aut/css#StateMachine> ;
    sh:property <http://www.w3id.org/hsu-aut/css#ServiceRequester-demands>,
        <http://www.w3id.org/hsu-aut/css#ServiceRequester-receives>,
        <http://www.w3id.org/hsu-aut/css#ServiceRequester-requiresProduct> .

<http://www.w3id.org/hsu-aut/css#Skill> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:comment """Executable implementation of an encapsulated (automation) function specified by a Capability.\r
\r
Notes:\r
- A skill must have a skill interface. \r
- One capability can be realized by more than one skill. \r
- A skill may have any number of SkillParameters. \r
- A skill’s behavior conforms to a state machine. \r
- A skill controls a process step""" ;
    owl:disjointWith <http://www.w3id.org/hsu-aut/css#SkillParameter> ;
    sh:property <http://www.w3id.org/hsu-aut/css#Skill-accessibleThrough>,
        <http://www.w3id.org/hsu-aut/css#Skill-behaviorConformsTo>,
        <http://www.w3id.org/hsu-aut/css#Skill-controls>,
        <http://www.w3id.org/hsu-aut/css#Skill-hasCurrentState>,
        <http://www.w3id.org/hsu-aut/css#Skill-hasParameter>,
        <http://www.w3id.org/hsu-aut/css#Skill-hasTrigger> .

<http://www.w3id.org/hsu-aut/css#SkillInterface> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:comment """Access point to configure, control and monitor a skill.\r
\r
Notes:\r
- A skill interface exposes interaction points to be used by other external systems\r
(e.g. MES, other skills).\r
- A skill interface exposes the state machine of a skill so that skill states can be\r
monitored and transitions triggered.\r
- A skill interface exposes the parameters of a skill so that they can be written and read.""" ;
    owl:disjointWith <http://www.w3id.org/hsu-aut/css#SkillParameter>,
        <http://www.w3id.org/hsu-aut/css#StateMachine> ;
    sh:property <http://www.w3id.org/hsu-aut/css#SkillInterface-exposes>,
        <http://www.w3id.org/hsu-aut/css#SkillInterface-exposesSkillParameter>,
        <http://www.w3id.org/hsu-aut/css#SkillInterface-exposesSkillTrigger>,
        <http://www.w3id.org/hsu-aut/css#SkillInterface-exposesStateMachine> .

<http://www.w3id.org/hsu-aut/css#SkillTrigger> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    sh:property <http://www.w3id.org/hsu-aut/css#SkillTrigger-hasParameter> .

<http://www.w3id.org/hsu-aut/css#State> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    sh:property <http://www.w3id.org/hsu-aut/css#State-hasIncomingTransition>,
        <http://www.w3id.org/hsu-aut/css#State-hasOutgoingTransition> .

<http://www.w3id.org/hsu-aut/css#StateMachine> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    sh:property <http://www.w3id.org/hsu-aut/css#StateMachine-consistsOfState>,
        <http://www.w3id.org/hsu-aut/css#StateMachine-consistsOfTransition> .

<http://www.w3id.org/hsu-aut/css#Transition> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    sh:property <http://www.w3id.org/hsu-aut/css#Transition-hasSourceState>,
        <http://www.w3id.org/hsu-aut/css#Transition-hasTargetState>,
        <http://www.w3id.org/hsu-aut/css#Transition-isInvokedBy> .

<http://www.w3id.org/hsu-aut/css#TransitionConstraint> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:comment "A TransitionConstraint is an expression between multiple Capabilities or Services, determining the applicability of a Capability or Service in a wider context. In a Transition-Constraint, a dependent Capability or Service is restricted by one or more referenced Capabilities or Services. TransitionConstraints can be used to formulate requirements going beyond PropertyConstraints, especially sequence requirements." ;
    rdfs:subClassOf <http://www.w3id.org/hsu-aut/css#Constraint> ;
    sh:property <http://www.w3id.org/hsu-aut/css#TransitionConstraint-references> .

<https://admin-shell.io/aas/3/1/AbstractLangString> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:label "Abstract Lang String"^^xsd:string ;
    rdfs:comment "Strings with language tags"@en ;
    sh:property <https://admin-shell.io/aas/3/1/AbstractLangString-https___admin-shell.io_aas_3_1_AbstractLangString_language>,
        <https://admin-shell.io/aas/3/1/AbstractLangString-https___admin-shell.io_aas_3_1_AbstractLangString_text> .

<https://admin-shell.io/aas/3/1/AdministrativeInformation> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:label "Administrative Information"^^xsd:string ;
    rdfs:comment "Administrative meta-information for an element like version information."@en ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/HasDataSpecification> ;
    sh:property <https://admin-shell.io/aas/3/1/AdministrativeInformation-https___admin-shell.io_aas_3_1_AdministrativeInformation_creator>,
        <https://admin-shell.io/aas/3/1/AdministrativeInformation-https___admin-shell.io_aas_3_1_AdministrativeInformation_revision>,
        <https://admin-shell.io/aas/3/1/AdministrativeInformation-https___admin-shell.io_aas_3_1_AdministrativeInformation_templateId>,
        <https://admin-shell.io/aas/3/1/AdministrativeInformation-https___admin-shell.io_aas_3_1_AdministrativeInformation_version> .

<https://admin-shell.io/aas/3/1/AnnotatedRelationshipElement> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:label "Annotated Relationship Element"^^xsd:string ;
    rdfs:comment "An annotated relationship element is a relationship element that can be annotated with additional data elements."@en ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/RelationshipElement> ;
    sh:property <https://admin-shell.io/aas/3/1/AnnotatedRelationshipElement-https___admin-shell.io_aas_3_1_AnnotatedRelationshipElement_annotations> .

<https://admin-shell.io/aas/3/1/AssetAdministrationShell> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:label "Asset Administration Shell"^^xsd:string ;
    rdfs:comment "An asset administration shell."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass <http://www.w3id.org/hsu-aut/css#Resource> ;
            owl:onProperty <https://w3id.org/2025/arso#representsResource> ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onClass <https://w3id.org/2025/arso#DigitalNameplateSubmodel> ;
            owl:onProperty <https://w3id.org/2025/arso#hasDigitalNameplateSubmodel> ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onClass <https://w3id.org/2025/arso#HierarchicalStructuresSubmodel> ;
            owl:onProperty <https://w3id.org/2025/arso#hasHierarchicalStructuresSubmodel> ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass <https://w3id.org/2025/arso#AIDSubmodel> ;
            owl:onProperty <https://w3id.org/2025/arso#hasAIDSubmodel> ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass <https://w3id.org/2025/arso#SkillsSubmodel> ;
            owl:onProperty <https://w3id.org/2025/arso#hasSkillsSubmodel> ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass <https://w3id.org/2025/arso#CapabilitiesSubmodel> ;
            owl:onProperty <https://w3id.org/2025/arso#hasCapabilitiesSubmodel> ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass <https://w3id.org/2025/arso#OperationalDataSubmodel> ;
            owl:onProperty <https://w3id.org/2025/arso#hasOperationalDataSubmodel> ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass <https://w3id.org/2025/arso#ParametersSubmodel> ;
            owl:onProperty <https://w3id.org/2025/arso#hasParametersSubmodel> ],
        <https://admin-shell.io/aas/3/1/HasDataSpecification>,
        <https://admin-shell.io/aas/3/1/Identifiable> ;
    sh:property <https://admin-shell.io/aas/3/1/AssetAdministrationShell-hasAIDSubmodel>,
        <https://admin-shell.io/aas/3/1/AssetAdministrationShell-hasCapabilitiesSubmodel>,
        <https://admin-shell.io/aas/3/1/AssetAdministrationShell-hasDigitalNameplateSubmodel>,
        <https://admin-shell.io/aas/3/1/AssetAdministrationShell-hasHierarchicalStructuresSubmodel>,
        <https://admin-shell.io/aas/3/1/AssetAdministrationShell-hasOperationalDataSubmodel>,
        <https://admin-shell.io/aas/3/1/AssetAdministrationShell-hasParametersSubmodel>,
        <https://admin-shell.io/aas/3/1/AssetAdministrationShell-hasSkillsSubmodel>,
        <https://admin-shell.io/aas/3/1/AssetAdministrationShell-hasSubmodel>,
        <https://admin-shell.io/aas/3/1/AssetAdministrationShell-https___admin-shell.io_aas_3_1_AssetAdministrationShell_assetInformation>,
        <https://admin-shell.io/aas/3/1/AssetAdministrationShell-https___admin-shell.io_aas_3_1_AssetAdministrationShell_derivedFrom>,
        <https://admin-shell.io/aas/3/1/AssetAdministrationShell-https___admin-shell.io_aas_3_1_AssetAdministrationShell_submodels>,
        <https://admin-shell.io/aas/3/1/AssetAdministrationShell-representsResource> .

<https://admin-shell.io/aas/3/1/AssetInformation> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:label "Asset Information"^^xsd:string ;
    rdfs:comment "In 'AssetInformation' identifying meta data of the asset that is represented by an AAS is defined."@en ;
    sh:property <https://admin-shell.io/aas/3/1/AssetInformation-https___admin-shell.io_aas_3_1_AssetInformation_assetKind>,
        <https://admin-shell.io/aas/3/1/AssetInformation-https___admin-shell.io_aas_3_1_AssetInformation_assetType>,
        <https://admin-shell.io/aas/3/1/AssetInformation-https___admin-shell.io_aas_3_1_AssetInformation_defaultThumbnail>,
        <https://admin-shell.io/aas/3/1/AssetInformation-https___admin-shell.io_aas_3_1_AssetInformation_globalAssetId>,
        <https://admin-shell.io/aas/3/1/AssetInformation-https___admin-shell.io_aas_3_1_AssetInformation_specificAssetIds> .

<https://admin-shell.io/aas/3/1/BasicEventElement> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:label "Basic Event Element"^^xsd:string ;
    rdfs:comment "A basic event element."@en ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/EventElement> ;
    sh:property <https://admin-shell.io/aas/3/1/BasicEventElement-https___admin-shell.io_aas_3_1_BasicEventElement_direction>,
        <https://admin-shell.io/aas/3/1/BasicEventElement-https___admin-shell.io_aas_3_1_BasicEventElement_lastUpdate>,
        <https://admin-shell.io/aas/3/1/BasicEventElement-https___admin-shell.io_aas_3_1_BasicEventElement_maxInterval>,
        <https://admin-shell.io/aas/3/1/BasicEventElement-https___admin-shell.io_aas_3_1_BasicEventElement_messageBroker>,
        <https://admin-shell.io/aas/3/1/BasicEventElement-https___admin-shell.io_aas_3_1_BasicEventElement_messageTopic>,
        <https://admin-shell.io/aas/3/1/BasicEventElement-https___admin-shell.io_aas_3_1_BasicEventElement_minInterval>,
        <https://admin-shell.io/aas/3/1/BasicEventElement-https___admin-shell.io_aas_3_1_BasicEventElement_observed>,
        <https://admin-shell.io/aas/3/1/BasicEventElement-https___admin-shell.io_aas_3_1_BasicEventElement_state> .

<https://admin-shell.io/aas/3/1/Blob> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:label "Blob"^^xsd:string ;
    rdfs:comment "A 'Blob' is a data element that represents a file that is contained with its source code in the value attribute."@en ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/DataElement> ;
    sh:property <https://admin-shell.io/aas/3/1/Blob-https___admin-shell.io_aas_3_1_Blob_contentType>,
        <https://admin-shell.io/aas/3/1/Blob-https___admin-shell.io_aas_3_1_Blob_value> .

<https://admin-shell.io/aas/3/1/ConceptDescription> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:label "Concept Description"^^xsd:string ;
    rdfs:comment "The semantics of a property or other elements that may have a semantic description is defined by a concept description."@en ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/HasDataSpecification>,
        <https://admin-shell.io/aas/3/1/Identifiable> ;
    sh:property <https://admin-shell.io/aas/3/1/ConceptDescription-https___admin-shell.io_aas_3_1_ConceptDescription_isCaseOf> .

<https://admin-shell.io/aas/3/1/DataSpecificationIec61360> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:label "Data Specification IEC 61360"^^xsd:string ;
    rdfs:comment "Content of data specification template for concept descriptions for properties, values and value lists conformant to IEC 61360."@en ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/DataSpecificationContent> ;
    sh:property <https://admin-shell.io/aas/3/1/DataSpecificationIec61360-https___admin-shell.io_aas_3_1_DataSpecificationIec61360_dataType>,
        <https://admin-shell.io/aas/3/1/DataSpecificationIec61360-https___admin-shell.io_aas_3_1_DataSpecificationIec61360_definition>,
        <https://admin-shell.io/aas/3/1/DataSpecificationIec61360-https___admin-shell.io_aas_3_1_DataSpecificationIec61360_levelType>,
        <https://admin-shell.io/aas/3/1/DataSpecificationIec61360-https___admin-shell.io_aas_3_1_DataSpecificationIec61360_preferredName>,
        <https://admin-shell.io/aas/3/1/DataSpecificationIec61360-https___admin-shell.io_aas_3_1_DataSpecificationIec61360_shortName>,
        <https://admin-shell.io/aas/3/1/DataSpecificationIec61360-https___admin-shell.io_aas_3_1_DataSpecificationIec61360_sourceOfDefinition>,
        <https://admin-shell.io/aas/3/1/DataSpecificationIec61360-https___admin-shell.io_aas_3_1_DataSpecificationIec61360_symbol>,
        <https://admin-shell.io/aas/3/1/DataSpecificationIec61360-https___admin-shell.io_aas_3_1_DataSpecificationIec61360_unit>,
        <https://admin-shell.io/aas/3/1/DataSpecificationIec61360-https___admin-shell.io_aas_3_1_DataSpecificationIec61360_unitId>,
        <https://admin-shell.io/aas/3/1/DataSpecificationIec61360-https___admin-shell.io_aas_3_1_DataSpecificationIec61360_value>,
        <https://admin-shell.io/aas/3/1/DataSpecificationIec61360-https___admin-shell.io_aas_3_1_DataSpecificationIec61360_valueFormat>,
        <https://admin-shell.io/aas/3/1/DataSpecificationIec61360-https___admin-shell.io_aas_3_1_DataSpecificationIec61360_valueList> .

