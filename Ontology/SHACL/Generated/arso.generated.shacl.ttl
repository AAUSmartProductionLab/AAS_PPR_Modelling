    rdfs:subClassOf <https://admin-shell.io/aas/3/1/MultiLanguageProperty> .

<https://w3id.org/2025/arso#UavEncodingProperty> a owl:Class ;
    rdfs:comment "Property encoding (xs:string) — message encoding, typically 'TCP Binary'. OPC UA EndpointMetadata." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/Property> .

<https://w3id.org/2025/arso#UavNamespaceIndexProperty> a owl:Class ;
    rdfs:comment "Property namespace_index (xs:string) — namespace index for application nodes, typically '1'. OPC UA EndpointMetadata." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/Property> .

<https://w3id.org/2025/arso#UavNamespaceProperty> a owl:Class ;
    rdfs:comment "Property opc_namespace (xs:string) — namespace index for the node, e.g. '1'. Used in Forms SMC." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/Property> .

<https://w3id.org/2025/arso#UavNamespaceUriProperty> a owl:Class ;
    rdfs:comment "Property namespace_uri (xs:string) — OPC UA application namespace URI from the NodeSet <NamespaceUri> element. OPC UA EndpointMetadata." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/Property> .

<https://w3id.org/2025/arso#UavNodeIdProperty> a owl:Class ;
    rdfs:comment "Property opc_node_id (xs:string) — full OPC UA NodeId string, e.g. 'ns=1;s=PlungerSet80/Methods/Start'. Used in Forms SMC for actions and properties." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/Property> .

<https://w3id.org/2025/arso#UavPortProperty> a owl:Class ;
    rdfs:comment "Property port (xs:string) — OPC UA endpoint port, typically '4840'. OPC UA EndpointMetadata." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/Property> .

<https://w3id.org/2025/arso#UavProtocolProperty> a owl:Class ;
    rdfs:comment "Property protocol (xs:string) — transport protocol, e.g. 'OPC UA'. OPC UA EndpointMetadata." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/Property> .

<https://w3id.org/2025/arso#UavSecurityModeProperty> a owl:Class ;
    rdfs:comment "Property security_mode (xs:string) — OPC UA MessageSecurityMode: None, Sign, or SignAndEncrypt." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/Property> .

<https://w3id.org/2025/arso#UavSecurityPolicyProperty> a owl:Class ;
    rdfs:comment "Property security_policy (xs:string) — OPC UA SecurityPolicy URI, e.g. Basic256Sha256." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/Property> .

<https://w3id.org/2025/arso#UavUserIdentityTokenProperty> a owl:Class ;
    rdfs:comment "Property user_token_type (xs:string) — OPC UA user identity token type: Anonymous, UserName, Certificate, or IssuedToken." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/Property> .

<https://w3id.org/2025/arso#UniqueFacilityIdentifierProperty> a owl:Class ;
    rdfs:comment "Property UniqueFacilityIdentifier (xs:string) — unique string for identification of locations/buildings in the product's value chain. semanticId: https://admin-shell.io/idta/nameplate/3/0/UniqueFacilityIdentifier. New in v3.0. Optional (0..1)." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/Property> .

<https://w3id.org/2025/arso#YearOfConstructionProperty> a owl:Class ;
    rdfs:comment "Property YearOfConstruction (xs:string) — year manufacturing process completed. semanticId: 0112/2///61987#ABP000#002. Optional (0..1); changed from mandatory in v2." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/Property> .

<https://w3id.org/2025/arso#hasAAS-shape> a sh:NodeShape ;
    sh:class <http://www.w3id.org/hsu-aut/css#Resource> ;
    sh:targetSubjectsOf <https://w3id.org/2025/arso#hasAAS> .

<https://w3id.org/2025/arso#hasSubmodel-shape> a sh:NodeShape ;
    sh:class <https://admin-shell.io/aas/3/1/AssetAdministrationShell> ;
    sh:targetSubjectsOf <https://w3id.org/2025/arso#hasSubmodel> .

<https://w3id.org/2025/arso#representsResource-shape> a sh:NodeShape ;
    sh:class <https://admin-shell.io/aas/3/1/AssetAdministrationShell> ;
    sh:targetSubjectsOf <https://w3id.org/2025/arso#representsResource> .

<http://www.w3id.org/hsu-aut/css> a owl:Ontology ;
    rdfs:comment """An ontology for the Capability, Skill and Service reference model defined by Plattform Industrie 4.0. See https://www.plattform-i40.de/IP/Redaktion/DE/Downloads/Publikation/CapabilitiesSkillsServices.html for a description of the abstract reference model.\r
\r
Includes extensions defined in https://www.plattform-i40.de/IP/Redaktion/DE/Downloads/Publikation/2025-i40-capabilities.pdf?__blob=publicationFile&v=5.""" ;
    rdfs:isDefinedBy "https://www.plattform-i40.de/IP/Redaktion/DE/Downloads/Publikation/2025-i40-capabilities.pdf?__blob=publicationFile&v=5",
        "https://www.plattform-i40.de/IP/Redaktion/DE/Downloads/Publikation/CapabilitiesSkillsServices.html" ;
    owl:versionIRI <http://www.w3id.org/hsu-aut/css/2.0.1> .

<http://www.w3id.org/hsu-aut/css#Capability-isRealizedBy> a sh:PropertyShape ;
    sh:path <http://www.w3id.org/hsu-aut/css#isRealizedBy> .

<http://www.w3id.org/hsu-aut/css#Capability-isRealizedBySkill> a sh:PropertyShape ;
    sh:class <http://www.w3id.org/hsu-aut/css#Skill> ;
    sh:path <http://www.w3id.org/hsu-aut/css#isRealizedBySkill> .

<http://www.w3id.org/hsu-aut/css#Capability-isRestrictedBy> a sh:PropertyShape ;
    sh:class <http://www.w3id.org/hsu-aut/css#Constraint> ;
    sh:path <http://www.w3id.org/hsu-aut/css#isRestrictedBy> .

<http://www.w3id.org/hsu-aut/css#Capability-isSpecifiedBy> a sh:PropertyShape ;
    sh:class <http://www.w3id.org/hsu-aut/css#Property> ;
    sh:path <http://www.w3id.org/hsu-aut/css#isSpecifiedBy> .

<http://www.w3id.org/hsu-aut/css#Process-hasInput> a sh:PropertyShape ;
    sh:class <http://www.w3id.org/hsu-aut/css#Product> ;
    sh:path <http://www.w3id.org/hsu-aut/css#hasInput> .

<http://www.w3id.org/hsu-aut/css#Process-hasOutput> a sh:PropertyShape ;
    sh:class <http://www.w3id.org/hsu-aut/css#Product> ;
    sh:path <http://www.w3id.org/hsu-aut/css#hasOutput> .

<http://www.w3id.org/hsu-aut/css#Process-requiresCapability> a sh:PropertyShape ;
    sh:class <http://www.w3id.org/hsu-aut/css#Capability> ;
    sh:path <http://www.w3id.org/hsu-aut/css#requiresCapability> .

<http://www.w3id.org/hsu-aut/css#Property-isRealizedBy> a sh:PropertyShape ;
    sh:path <http://www.w3id.org/hsu-aut/css#isRealizedBy> .

<http://www.w3id.org/hsu-aut/css#Property-isRealizedBySkillParameter> a sh:PropertyShape ;
    sh:class <http://www.w3id.org/hsu-aut/css#SkillParameter> ;
    sh:path <http://www.w3id.org/hsu-aut/css#isRealizedBySkillParameter> .

<http://www.w3id.org/hsu-aut/css#PropertyConstraint-referencesProperty> a sh:PropertyShape ;
    sh:class <http://www.w3id.org/hsu-aut/css#Property> ;
    sh:path <http://www.w3id.org/hsu-aut/css#referencesProperty> .

<http://www.w3id.org/hsu-aut/css#Resource-behaviorConformsTo> a sh:PropertyShape ;
    sh:class <http://www.w3id.org/hsu-aut/css#StateMachine> ;
    sh:path <http://www.w3id.org/hsu-aut/css#behaviorConformsTo> .

<http://www.w3id.org/hsu-aut/css#Resource-hasAAS> a sh:PropertyShape ;
    sh:class <https://admin-shell.io/aas/3/1/AssetAdministrationShell> ;
    sh:maxCount 1 ;
    sh:minCount 1 ;
    sh:path <https://w3id.org/2025/arso#hasAAS> .

<http://www.w3id.org/hsu-aut/css#Resource-provides> a sh:PropertyShape ;
    sh:path <http://www.w3id.org/hsu-aut/css#provides> .

<http://www.w3id.org/hsu-aut/css#Resource-providesCapability> a sh:PropertyShape ;
    sh:class <http://www.w3id.org/hsu-aut/css#Capability> ;
    sh:path <http://www.w3id.org/hsu-aut/css#providesCapability> .

<http://www.w3id.org/hsu-aut/css#Resource-providesSkill> a sh:PropertyShape ;
    sh:class <http://www.w3id.org/hsu-aut/css#Skill> ;
    sh:path <http://www.w3id.org/hsu-aut/css#providesSkill> .

<http://www.w3id.org/hsu-aut/css#Service-assures> a sh:PropertyShape ;
    sh:class <http://www.w3id.org/hsu-aut/css#Product> ;
    sh:path <http://www.w3id.org/hsu-aut/css#assures> .

<http://www.w3id.org/hsu-aut/css#Service-isInputFor> a sh:PropertyShape ;
    sh:class <http://www.w3id.org/hsu-aut/css#ServiceOffer> ;
    sh:path <http://www.w3id.org/hsu-aut/css#isInputFor> .

<http://www.w3id.org/hsu-aut/css#Service-isSpecifiedBy> a sh:PropertyShape ;
    sh:class <http://www.w3id.org/hsu-aut/css#Property> ;
    sh:path <http://www.w3id.org/hsu-aut/css#isSpecifiedBy> .

<http://www.w3id.org/hsu-aut/css#Service-offersUseOf> a sh:PropertyShape ;
