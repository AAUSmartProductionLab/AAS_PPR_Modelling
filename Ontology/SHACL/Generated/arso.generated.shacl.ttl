<https://w3id.org/2025/arso#HasPartRelationship> a owl:Class ;
    rdfs:comment "RelationshipElement HasPart — parent→child logical connection. Mutually exclusive with IsPartOf per entity. Both first and second must reference an EntryNodeEntity or NodeEntity in the same submodel." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/RelationshipElement> .

<https://w3id.org/2025/arso#HtvMethodNameProperty> a owl:Class ;
    rdfs:comment "Property htv_methodName (xs:string) — HTTP method (GET, POST, PUT, DELETE, PATCH)." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/Property> .

<https://w3id.org/2025/arso#InteractionMetadataSMC> a owl:Class ;
