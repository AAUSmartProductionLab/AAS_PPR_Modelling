    rdfs:comment "An element that is referable by its 'idShort'."@en ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/HasExtensions> ;
    sh:property <https://admin-shell.io/aas/3/1/Referable-https___admin-shell.io_aas_3_1_Referable_category>,
        <https://admin-shell.io/aas/3/1/Referable-https___admin-shell.io_aas_3_1_Referable_description>,
        <https://admin-shell.io/aas/3/1/Referable-https___admin-shell.io_aas_3_1_Referable_displayName>,
        <https://admin-shell.io/aas/3/1/Referable-https___admin-shell.io_aas_3_1_Referable_idShort> .

<https://admin-shell.io/aas/3/1/Reference> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:label "Reference"^^xsd:string ;
    rdfs:comment "Reference to either a model element of the same or another AAS or to an external entity."@en ;
    sh:property <https://admin-shell.io/aas/3/1/Reference-https___admin-shell.io_aas_3_1_Reference_keys>,
        <https://admin-shell.io/aas/3/1/Reference-https___admin-shell.io_aas_3_1_Reference_referredSemanticId>,
        <https://admin-shell.io/aas/3/1/Reference-https___admin-shell.io_aas_3_1_Reference_type> .

<https://admin-shell.io/aas/3/1/ReferenceElement> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:label "Reference Element"^^xsd:string ;
    rdfs:comment "A reference element is a data element that defines a logical reference to another element within the same or another AAS or a reference to an external object or entity."@en ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/DataElement> ;
    sh:property <https://admin-shell.io/aas/3/1/ReferenceElement-https___admin-shell.io_aas_3_1_ReferenceElement_value> .

<https://admin-shell.io/aas/3/1/RelationshipElement> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:label "Relationship Element"^^xsd:string ;
    rdfs:comment "A relationship element is used to define a relationship between two elements being either referable (model reference) or external (global reference)."@en ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/SubmodelElement> ;
    sh:property <https://admin-shell.io/aas/3/1/RelationshipElement-https___admin-shell.io_aas_3_1_RelationshipElement_first>,
        <https://admin-shell.io/aas/3/1/RelationshipElement-https___admin-shell.io_aas_3_1_RelationshipElement_second> .

<https://admin-shell.io/aas/3/1/Resource> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:label "Resource"^^xsd:string ;
    rdfs:comment "Resource represents an address to a file (a locator). The value is an URI that can represent an absolute or relative path"@en ;
    sh:property <https://admin-shell.io/aas/3/1/Resource-https___admin-shell.io_aas_3_1_Resource_contentType>,
        <https://admin-shell.io/aas/3/1/Resource-https___admin-shell.io_aas_3_1_Resource_path> .

<https://admin-shell.io/aas/3/1/SpecificAssetId> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:label "Specific Asset ID"^^xsd:string ;
    rdfs:comment "A specific asset ID describes a generic supplementary identifying attribute of the asset."@en ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/HasSemantics> ;
    sh:property <https://admin-shell.io/aas/3/1/SpecificAssetId-https___admin-shell.io_aas_3_1_SpecificAssetId_externalSubjectId>,
        <https://admin-shell.io/aas/3/1/SpecificAssetId-https___admin-shell.io_aas_3_1_SpecificAssetId_name>,
        <https://admin-shell.io/aas/3/1/SpecificAssetId-https___admin-shell.io_aas_3_1_SpecificAssetId_value> .

<https://admin-shell.io/aas/3/1/Submodel> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:label "Submodel"^^xsd:string ;
    rdfs:comment "A submodel defines a specific aspect of the asset represented by the AAS."@en ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/HasDataSpecification>,
        <https://admin-shell.io/aas/3/1/HasKind>,
        <https://admin-shell.io/aas/3/1/HasSemantics>,
        <https://admin-shell.io/aas/3/1/Identifiable>,
        <https://admin-shell.io/aas/3/1/Qualifiable> ;
    sh:property <https://admin-shell.io/aas/3/1/Submodel-https___admin-shell.io_aas_3_1_Submodel_submodelElements> .

<https://admin-shell.io/aas/3/1/SubmodelElementCollection> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:label "Submodel Element Collection"^^xsd:string ;
    rdfs:comment "A submodel element collection is a kind of struct, i.e. a a logical encapsulation of multiple named values. It has a fixed number of submodel elements."@en ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/SubmodelElement> ;
    sh:property <https://admin-shell.io/aas/3/1/SubmodelElementCollection-https___admin-shell.io_aas_3_1_SubmodelElementCollection_value> .

<https://admin-shell.io/aas/3/1/SubmodelElementList> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:label "Submodel Element List"^^xsd:string ;
    rdfs:comment "A submodel element list is an ordered list of submodel elements."@en ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/SubmodelElement> ;
    sh:property <https://admin-shell.io/aas/3/1/SubmodelElementList-https___admin-shell.io_aas_3_1_SubmodelElementList_orderRelevant>,
        <https://admin-shell.io/aas/3/1/SubmodelElementList-https___admin-shell.io_aas_3_1_SubmodelElementList_semanticIdListElement>,
        <https://admin-shell.io/aas/3/1/SubmodelElementList-https___admin-shell.io_aas_3_1_SubmodelElementList_typeValueListElement>,
        <https://admin-shell.io/aas/3/1/SubmodelElementList-https___admin-shell.io_aas_3_1_SubmodelElementList_value>,
        <https://admin-shell.io/aas/3/1/SubmodelElementList-https___admin-shell.io_aas_3_1_SubmodelElementList_valueTypeListElement> .

<https://admin-shell.io/aas/3/1/ValueList> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:label "Value List"^^xsd:string ;
    rdfs:comment "A set of value reference pairs."@en ;
    sh:property <https://admin-shell.io/aas/3/1/ValueList-https___admin-shell.io_aas_3_1_ValueList_valueReferencePairs> .

<https://admin-shell.io/aas/3/1/ValueReferencePair> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:label "Value Reference Pair"^^xsd:string ;
    rdfs:comment "A value reference pair within a value list. Each value has a global unique id defining its semantic."@en ;
    sh:property <https://admin-shell.io/aas/3/1/ValueReferencePair-https___admin-shell.io_aas_3_1_ValueReferencePair_value>,
        <https://admin-shell.io/aas/3/1/ValueReferencePair-https___admin-shell.io_aas_3_1_ValueReferencePair_valueId> .

<https://w3id.org/2025/arso#AIDSubmodel> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:label "Asset Interfaces Description Submodel" ;
    rdfs:comment "IDTA 02017 — Asset Interfaces Description." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://admin-shell.io/aas/3/1/Submodel/submodelElements> ;
            owl:someValuesFrom <https://w3id.org/2025/arso#InterfaceSMC> ],
        <https://admin-shell.io/aas/3/1/Submodel> ;
    sh:property <https://w3id.org/2025/arso#AIDSubmodel-https___admin-shell.io_aas_3_1_Submodel_submodelElements> .

<https://w3id.org/2025/arso#ActionDefinitionSMC> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:comment "SMC {action_name} — an ActionAffordance (invokable operation). Must have a forms SMC." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://admin-shell.io/aas/3/1/SubmodelElementCollection/value> ;
            owl:someValuesFrom <https://w3id.org/2025/arso#FormsSMC> ],
        <https://admin-shell.io/aas/3/1/SubmodelElementCollection> ;
    sh:property <https://w3id.org/2025/arso#ActionDefinitionSMC-https___admin-shell.io_aas_3_1_SubmodelElementCollection_value> .

<https://w3id.org/2025/arso#ActionsSMC> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:comment "SMC actions — container for ActionDefinition SMCs (WoT ActionAffordances)." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/2025/arso#ActionDefinitionSMC> ;
            owl:onProperty <https://admin-shell.io/aas/3/1/SubmodelElementCollection/value> ],
        <https://admin-shell.io/aas/3/1/SubmodelElementCollection> ;
    sh:property <https://w3id.org/2025/arso#ActionsSMC-https___admin-shell.io_aas_3_1_SubmodelElementCollection_value> .

<https://w3id.org/2025/arso#AddressInformationSMC> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:comment "SMC AddressInformation — drop-in from IDTA 02002 (Contact Informations). semanticId: https://admin-shell.io/zvei/nameplate/1/0/ContactInformations/AddressInformation. Mandatory per IDTA 02006-3-0." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty <https://admin-shell.io/aas/3/1/SubmodelElementCollection/value> ;
            owl:someValuesFrom <https://w3id.org/2025/arso#AddressZipcodeMLP> ],
        [ a owl:Restriction ;
            owl:onProperty <https://admin-shell.io/aas/3/1/SubmodelElementCollection/value> ;
            owl:someValuesFrom <https://w3id.org/2025/arso#AddressCityTownMLP> ],
        [ a owl:Restriction ;
            owl:onProperty <https://admin-shell.io/aas/3/1/SubmodelElementCollection/value> ;
            owl:someValuesFrom <https://w3id.org/2025/arso#AddressNationalCodeMLP> ],
        [ a owl:Restriction ;
            owl:onProperty <https://admin-shell.io/aas/3/1/SubmodelElementCollection/value> ;
            owl:someValuesFrom <https://w3id.org/2025/arso#AddressStreetMLP> ],
        <https://admin-shell.io/aas/3/1/SubmodelElementCollection> ;
    sh:property <https://w3id.org/2025/arso#AddressInformationSMC-https___admin-shell.io_aas_3_1_SubmodelElementCollection_value> .

<https://w3id.org/2025/arso#ArcheTypeProperty> a rdfs:Class,
        owl:Class,
        sh:NodeShape ;
    rdfs:comment "Property ArcheType (xs:string) — hierarchy archetype: 'Full', 'OneDown', or 'OneUp'. Value constraint enforced via SPARQL SHACL." ;
    rdfs:subClassOf [ a owl:Restriction ;
