    rdfs:subClassOf <https://admin-shell.io/aas/3/1/SubmodelElementCollection> .

<https://w3id.org/2025/arso#InterfaceCreatedProperty> a owl:Class ;
    rdfs:comment "Property created (xs:dateTime) — creation timestamp of the Interface." ;
    rdfs:subClassOf <https://admin-shell.io/aas/3/1/Property> .

<https://w3id.org/2025/arso#InterfaceModifiedProperty> a owl:Class ;
