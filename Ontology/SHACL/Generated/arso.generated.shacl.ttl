    sh:path <http://www.w3id.org/hsu-aut/css#offers> .

<http://www.w3id.org/hsu-aut/css#ServiceProvider-proposes> a sh:PropertyShape ;
    sh:class <http://www.w3id.org/hsu-aut/css#ServiceOffer> ;
    sh:path <http://www.w3id.org/hsu-aut/css#proposes> .

<http://www.w3id.org/hsu-aut/css#ServiceRequester-demands> a sh:PropertyShape ;
    sh:class <http://www.w3id.org/hsu-aut/css#Service> ;
    sh:path <http://www.w3id.org/hsu-aut/css#demands> .

<http://www.w3id.org/hsu-aut/css#ServiceRequester-receives> a sh:PropertyShape ;
