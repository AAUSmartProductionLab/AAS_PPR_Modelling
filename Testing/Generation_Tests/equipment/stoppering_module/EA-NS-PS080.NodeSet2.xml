  <!-- Method: Start -->
  <UAMethod
    NodeId="ns=1;i=4000"
    BrowseName="1:Start"
    Executable="true"
    UserExecutable="true">
    <DisplayName>Start</DisplayName>
    <Description>
      Initiates a single stoppering cycle.
      Preconditions: State == "IDLE" AND MagazineCount > 0.
      Sequence: servo advances one plunger to insertion chamber;
                lift lowers to insertion height;
                linear actuator extends (insertion stroke 20 mm);
                linear actuator retracts;
                lift returns to home position;
                MagazineCount decremented;
                CycleTime updated;
                State transitions IDLE -> RUNNING -> IDLE.
      Returns: StatusCode Good on acceptance; Bad_InvalidState if precondition not met.
      Expected cycle duration: approximately 5 – 12 seconds depending on plunger type.
    </Description>
    <References>
      <Reference ReferenceType="HasTypeDefinition">i=77</Reference>
      <Reference ReferenceType="HasModellingRule">i=78</Reference>
      <Reference ReferenceType="HasProperty">ns=1;i=4000-InputArgs</Reference>
      <Reference ReferenceType="HasProperty">ns=1;i=4000-OutputArgs</Reference>
    </References>
  </UAMethod>

