  <!-- Method: Reset -->
  <UAMethod
    NodeId="ns=1;i=4003"
    BrowseName="1:Reset"
    Executable="true"
    UserExecutable="true">
    <DisplayName>Reset</DisplayName>
    <Description>
      Clears an active fault condition and returns State to IDLE.
      Preconditions: State == "ERROR".
      Behaviour: ErrorCode register is set to 0x0000;
                 all actuators are de-energised (safe state);
                 State transitions ERROR -> IDLE.
      Note: Reset does NOT re-home the lift. A Home call is recommended after
            INSERTION_FAULT (0x0002) or ACTUATOR_RETRACT (0x0020) to ensure
            correct positional reference.
      Returns: StatusCode Good on acceptance; Bad_InvalidState if State != ERROR.
    </Description>
    <References>
      <Reference ReferenceType="HasTypeDefinition">i=77</Reference>
      <Reference ReferenceType="HasModellingRule">i=78</Reference>
      <Reference ReferenceType="HasProperty">ns=1;i=4003-InputArgs</Reference>
      <Reference ReferenceType="HasProperty">ns=1;i=4003-OutputArgs</Reference>
    </References>
  </UAMethod>

