  <!-- Method: Home -->
  <UAMethod
    NodeId="ns=1;i=4002"
    BrowseName="1:Home"
    Executable="true"
    UserExecutable="true">
    <DisplayName>Home</DisplayName>
    <Description>
      Executes a lift homing sequence.
      Accepted in any state (including ERROR and HOMING).
      Behaviour: Lift motor drives down until the homing limit switch is actuated;
                 position reference is set;
                 lift raises to standby height (10 mm above home).
      State transitions: * -> HOMING -> IDLE.
      Timeout: 15 seconds (generates ErrorCode 0x0001 HOMING_TIMEOUT if limit switch not reached).
      Returns: StatusCode Good on acceptance.
      Note: Home MUST be called at least once after power-on before issuing Start.
             The State variable will read "ERROR" with ErrorCode 0x0001 on power-on
             until the first successful Home cycle completes.
    </Description>
    <References>
      <Reference ReferenceType="HasTypeDefinition">i=77</Reference>
      <Reference ReferenceType="HasModellingRule">i=78</Reference>
      <Reference ReferenceType="HasProperty">ns=1;i=4002-InputArgs</Reference>
      <Reference ReferenceType="HasProperty">ns=1;i=4002-OutputArgs</Reference>
    </References>
  </UAMethod>

  <UAVariable NodeId="ns=1;i=4002-InputArgs" BrowseName="InputArguments"
    DataType="Argument" ValueRank="1" ArrayDimensions="0">
    <DisplayName>InputArguments</DisplayName>
    <References>
      <Reference ReferenceType="HasTypeDefinition">i=68</Reference>
      <Reference ReferenceType="HasModellingRule">i=78</Reference>
    </References>
    <Value><uax:ListOfExtensionObject/></Value>
  </UAVariable>

  <UAVariable NodeId="ns=1;i=4002-OutputArgs" BrowseName="OutputArguments"
