  <!-- Method: Stop -->
  <UAMethod
    NodeId="ns=1;i=4001"
    BrowseName="1:Stop"
    Executable="true"
    UserExecutable="true">
    <DisplayName>Stop</DisplayName>
    <Description>
      Halts the current stoppering cycle immediately.
      Preconditions: State == "RUNNING".
      Behaviour: All actuators de-energised; lift returns to homed position.
      CycleTime is NOT updated (partial cycle).
      MagazineCount is NOT decremented (plunger not inserted).
      State transitions: RUNNING -> IDLE.
      Returns: StatusCode Good on acceptance; Bad_InvalidState if State != RUNNING.
    </Description>
    <References>
      <Reference ReferenceType="HasTypeDefinition">i=77</Reference>
      <Reference ReferenceType="HasModellingRule">i=78</Reference>
      <Reference ReferenceType="HasProperty">ns=1;i=4001-InputArgs</Reference>
      <Reference ReferenceType="HasProperty">ns=1;i=4001-OutputArgs</Reference>
    </References>
  </UAMethod>

  <UAVariable NodeId="ns=1;i=4001-InputArgs" BrowseName="InputArguments"
